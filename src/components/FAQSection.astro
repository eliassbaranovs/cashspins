---
interface Props {
  faqs?: Array<{ question: string; answer: string }>;
}
const { faqs } = Astro.props;
const hasFaqs = faqs && faqs.length > 0;
---

{hasFaqs && (
  <section>
    <h2 class="font-headline font-bold text-2xl text-on-surface mb-8">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faqs!.map((faq) => (
        <details class="group bg-surface-container-low rounded-xl">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-headline font-semibold text-on-surface list-none [&::-webkit-details-marker]:hidden">
            <span>{faq.question}</span>
            <span class="material-symbols-outlined text-on-surface-variant transition-transform duration-300 group-open:rotate-180 shrink-0 ml-4">expand_more</span>
          </summary>
          <div class="px-6 pb-6 pt-0 text-on-surface-variant leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </section>
)}
