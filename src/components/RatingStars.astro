---
interface Props {
  rating: number; // 0–10 scale
}
const { rating = 0 } = Astro.props;

// Convert 0-10 to 0-5 star scale
const stars5 = Math.max(0, Math.min(5, rating / 2));
const fullStars = Math.floor(stars5);
const hasHalf = stars5 - fullStars >= 0.25 && stars5 - fullStars < 0.75;
const adjustedFull = stars5 - fullStars >= 0.75 ? fullStars + 1 : fullStars;
const emptyStars = 5 - adjustedFull - (hasHalf ? 1 : 0);
---

<span class="inline-flex items-center gap-0.5" aria-label={`Rating: ${rating} out of 10`}>
  {Array.from({ length: adjustedFull }).map(() => (
    <span class="material-symbols-outlined text-tertiary text-lg" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">star</span>
  ))}
  {hasHalf && (
    <span class="material-symbols-outlined text-tertiary text-lg" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">star_half</span>
  )}
  {Array.from({ length: Math.max(0, emptyStars) }).map(() => (
    <span class="material-symbols-outlined text-surface-container-highest text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">star</span>
  ))}
</span>
