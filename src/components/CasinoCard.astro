---
import LicenseBadge from "./LicenseBadge.astro";
import RatingBadge from "./RatingBadge.astro";

interface Props {
  casino: {
    data: {
      name?: string;
      slug: string;
      rating?: number | null;
      best_for?: string | null;
      bonus_value?: string | null;
      bonus_wagering?: string | null;
      logo?: string | null;
      excerpt?: string;
      pros?: string[];
      claim_url?: string | null;
      website_url?: string | null;
      categories?: string[];
      license?: string | null;
      license_status?: string | null;
    };
  };
  rank?: number;
}

const { casino, rank } = Astro.props;
const d = casino.data;
const name = d.name || d.slug;
const topPros = d.pros?.slice(0, 2) || [];

// Top 3 get medal styling; everything else gets a muted numeric chip.
const rankStyle = rank === 1
  ? "bg-yellow-400 text-neutral-900"
  : rank === 2
  ? "bg-slate-300 text-neutral-900"
  : rank === 3
  ? "bg-amber-600 text-white"
  : "bg-surface-container-highest text-on-surface-variant";

// #1 earns an Editor's Pick accent ring + eyebrow label.
const featured = rank === 1;

// Wagering is sometimes a full sentence; cap it for the card.
const wagering = d.bonus_wagering
  ? (d.bonus_wagering.length > 48 ? d.bonus_wagering.slice(0, 45).trimEnd() + "…" : d.bonus_wagering)
  : null;
---

<div class:list={[
  "group relative bg-surface-container-low rounded-xl p-4 sm:p-6 hover:bg-surface-container-high ghost-border transition-all overflow-hidden min-h-44",
  featured && "ring-1 ring-yellow-400/40",
]}>
  {/* Green accent bar on hover */}
  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-16 bg-primary rounded-r-full opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>

  {featured && (
    <span class="absolute top-0 right-6 bg-yellow-400 text-neutral-900 text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-b-sm">
      Editor's Pick
    </span>
  )}

  <div class="flex flex-col lg:flex-row gap-6 items-start lg:items-center">
    {/* Logo + Rank */}
    <div class="shrink-0 relative">
      {rank != null && (
        <span class={`absolute -top-2 -left-2 z-10 w-8 h-8 rounded-full flex items-center justify-center text-xs font-headline font-black shadow-md ${rankStyle}`}>
          {rank}
        </span>
      )}
      {d.logo ? (
        <img
          src={d.logo}
          alt={`${name} logo`}
          class="w-28 h-28 rounded-xl bg-surface-container-lowest object-contain p-3"
          loading="lazy"
        />
      ) : (
        <div class="w-28 h-28 rounded-xl bg-surface-container-lowest flex items-center justify-center">
          <span class="material-symbols-outlined text-outline text-4xl">casino</span>
        </div>
      )}
    </div>

    {/* Center info */}
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 flex-wrap mb-1">
        <h3 class="text-2xl font-headline font-bold text-on-surface">{name}</h3>
        {d.rating != null && <RatingBadge rating={d.rating} size="sm" />}
      </div>
      {d.best_for && (
        <p class="text-on-surface-variant text-sm mb-2">{d.best_for}</p>
      )}
      {d.license && (
        <div class="mb-2">
          <LicenseBadge license={d.license} licenseStatus={d.license_status} size="sm" />
        </div>
      )}
      {topPros.length > 0 && (
        <ul class="space-y-1">
          {topPros.map((pro) => (
            <li class="flex items-center gap-2 text-sm text-on-surface-variant">
              <span class="material-symbols-outlined text-primary text-base">check</span>
              <span>{pro}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    {/* Bonus column */}
    {d.bonus_value && (
      <div class="shrink-0 text-center lg:text-right max-w-56">
        <span class="text-xs font-label text-on-surface-variant uppercase tracking-wider block mb-1">Welcome Package</span>
        <span class="text-primary font-headline font-extrabold text-lg leading-tight block line-clamp-2">{d.bonus_value}</span>
        {wagering && (
          <span class="text-xs font-label text-on-surface-variant block mt-1">
            <span class="uppercase tracking-wider">Wagering:</span>
            <span class="text-on-surface font-bold ml-1">{wagering}</span>
          </span>
        )}
      </div>
    )}

    {/* CTA buttons */}
    <div class="flex flex-col sm:flex-row lg:flex-col gap-3 shrink-0 w-full lg:w-auto">
      {(d.claim_url || d.website_url) && (
        <a
          href={`/go/${d.slug}/`}
          rel="nofollow sponsored"
          target="_blank"
          class="liquid-gradient text-on-primary-fixed-variant font-headline font-bold rounded-md px-6 py-3 text-center shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-transform whitespace-nowrap flex-1 lg:flex-none"
        >
          Claim Bonus
        </a>
      )}
      <a
        href={`/casinos/${d.slug}/`}
        class="border border-outline-variant/30 text-on-surface-variant rounded-md px-6 py-3 text-center hover:bg-surface-container-highest transition-all whitespace-nowrap flex-1 lg:flex-none"
      >
        Read Review
      </a>
    </div>
  </div>
</div>
