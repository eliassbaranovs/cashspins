---
interface Props {
  bonus: {
    data: {
      casino_name?: string;
      casino_slug?: string;
      slug: string;
      bonus_value?: string | null;
      bonus_wagering?: string | null;
      bonus_min_deposit?: string | null;
      logo?: string | null;
    };
  };
}

const { bonus } = Astro.props;
const d = bonus.data;
const name = d.casino_name || d.casino_slug || d.slug;
const casinoSlug = d.casino_slug || d.slug;
---

<div class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container-high ghost-border transition-all">
  <div class="grid grid-cols-[auto_1fr_auto] gap-6 items-center">

    {/* Logo — large to give the card height */}
    <div class="shrink-0">
      {d.logo ? (
        <img
          src={d.logo}
          alt={`${name} logo`}
          class="w-28 h-28 rounded-xl bg-surface-container-lowest object-contain p-3"
          loading="lazy"
        />
      ) : (
        <div class="w-28 h-28 rounded-xl bg-surface-container-lowest flex items-center justify-center">
          <span class="material-symbols-outlined text-outline text-4xl">redeem</span>
        </div>
      )}
    </div>

    {/* Content — stacked: title on top, stats below */}
    <div class="min-w-0 flex flex-col justify-center gap-3">
      {/* Name + bonus title */}
      <div class="min-w-0">
        <p class="text-on-surface-variant text-xs font-label tracking-wide">{name}</p>
        {d.bonus_value && (
          <h3 class="font-headline font-bold text-lg text-primary mt-0.5 line-clamp-2">{d.bonus_value}</h3>
        )}
      </div>

      {/* Stats pills row */}
      <div class="flex flex-wrap gap-2.5 items-center">
        {d.bonus_wagering && (
          <div class="bg-surface-container rounded-lg px-4 py-2 text-center max-w-sm">
            <span class="block text-[10px] font-label text-on-surface-variant uppercase tracking-widest">Wagering</span>
            <span class="block text-sm font-bold text-on-surface line-clamp-1">{d.bonus_wagering}</span>
          </div>
        )}
        {d.bonus_min_deposit && (
          <div class="bg-surface-container rounded-lg px-3.5 py-2 text-center">
            <span class="block text-[10px] font-label text-on-surface-variant uppercase tracking-widest">Min Deposit</span>
            <span class="block text-sm font-bold text-on-surface">{d.bonus_min_deposit}</span>
          </div>
        )}
      </div>
    </div>

    {/* CTAs */}
    <div class="flex flex-col gap-2 shrink-0">
      <a
        href={`/go/${casinoSlug}/`}
        rel="nofollow sponsored"
        target="_blank"
        class="liquid-gradient text-on-primary-fixed-variant font-headline font-bold rounded-md px-5 py-2.5 text-center shadow-lg shadow-primary/20 hover:scale-105 transition-transform whitespace-nowrap text-sm"
      >
        Claim Bonus
      </a>
      <a
        href={`/bonus/${d.slug}/`}
        class="border border-outline-variant/30 text-on-surface-variant rounded-md px-5 py-2.5 text-center hover:bg-surface-container-highest transition-all whitespace-nowrap text-sm"
      >
        Read Review
      </a>
    </div>
  </div>
</div>
