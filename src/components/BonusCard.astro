---
interface Props {
  bonus: {
    data: {
      casinoName?: string;
      slug: string;
      bonus_title?: string;
      bonus_percentage?: number;
      wagering?: string;
      free_spins?: number | string;
      logo?: string;
      min_deposit?: string;
      casino?: string;
    };
  };
}

const { bonus } = Astro.props;
const d = bonus.data;
const name = d.casinoName || d.casino || d.slug;
const casinoSlug = d.casino || d.slug;

const stats = [
  d.wagering ? { label: "Wagering", value: d.wagering } : null,
  d.min_deposit ? { label: "Min Deposit", value: d.min_deposit } : null,
  d.free_spins ? { label: "Free Spins", value: String(d.free_spins) } : null,
  d.bonus_percentage ? { label: "Match", value: `${d.bonus_percentage}%` } : null,
].filter(Boolean) as Array<{ label: string; value: string }>;
---

<div class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container-high ghost-border transition-all">
  <div class="flex flex-col sm:flex-row gap-5 items-start">
    {/* Logo */}
    <div class="shrink-0">
      {d.logo ? (
        <img
          src={d.logo}
          alt={`${name} logo`}
          class="w-24 h-24 rounded-xl bg-surface-container-lowest object-contain p-2"
          loading="lazy"
        />
      ) : (
        <div class="w-24 h-24 rounded-xl bg-surface-container-lowest flex items-center justify-center">
          <span class="material-symbols-outlined text-outline text-3xl">redeem</span>
        </div>
      )}
    </div>

    {/* Content */}
    <div class="flex-1 min-w-0">
      <p class="text-on-surface-variant text-sm font-label mb-1">{name}</p>
      {d.bonus_title && (
        <h3 class="font-headline font-bold text-lg text-primary mb-3">{d.bonus_title}</h3>
      )}

      {/* Stats row */}
      {stats.length > 0 && (
        <div class="flex flex-wrap gap-4 mb-4">
          {stats.map((stat) => (
            <div class="text-center">
              <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">{stat.label}</span>
              <span class="block text-sm font-bold text-on-surface">{stat.value}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    {/* CTAs */}
    <div class="flex flex-row sm:flex-col gap-3 shrink-0">
      <a
        href={`/go/${casinoSlug}/`}
        rel="nofollow sponsored"
        target="_blank"
        class="liquid-gradient text-on-primary-fixed-variant font-headline font-bold rounded-md px-5 py-2.5 text-center shadow-lg shadow-primary/20 hover:scale-105 transition-transform whitespace-nowrap text-sm"
      >
        Claim Bonus
      </a>
      <a
        href={`/bonus/${d.slug}/`}
        class="border border-outline-variant/30 text-on-surface-variant rounded-md px-5 py-2.5 text-center hover:bg-surface-container-highest transition-all whitespace-nowrap text-sm"
      >
        Read Review
      </a>
    </div>
  </div>
</div>
