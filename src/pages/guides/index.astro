---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

let allGuides: Awaited<ReturnType<typeof getCollection>> = [];
try {
  allGuides = await getCollection("guides");
} catch {
  allGuides = [];
}

const guides = allGuides
  .filter((g: any) => !g.data.draft)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.publishedAt).getTime() -
      new Date(a.data.publishedAt).getTime()
  );

// Derive category tags
const allTags = [...new Set(guides.flatMap((g: any) => g.data.tags ?? []))];

const featured = guides[0];
const rest = guides.slice(1);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Guides" },
];
---

<BaseLayout
  title="Casino Guides & Strategy | CashSpins"
  seoTitle="Casino Guides & Strategy 2026 — Expert Tips | CashSpins"
  description="In-depth casino guides covering game strategies, bonus optimization, responsible gambling, and everything you need to play smarter. Written by CashSpins experts."
>
  <div class="max-w-screen-2xl mx-auto px-8 pt-8 pb-20">
    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-4">
        Expert <span class="text-primary">Guides</span>
      </h1>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl leading-relaxed">
        Comprehensive guides covering game strategies, bonus mechanics, and responsible gambling — written for players who want to play smarter.
      </p>
    </header>

    {guides.length > 0 ? (
      <>
        {/* Category Filter Pills */}
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-3 mb-10">
            <span class="px-5 py-2 rounded-full text-sm font-bold bg-primary text-on-primary shadow-md cursor-pointer">
              All Guides
            </span>
            {allTags.slice(0, 8).map((tag: string) => (
              <span class="px-5 py-2 rounded-full text-sm font-bold bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-all cursor-pointer">
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Featured Guide */}
        {featured && (
          <a href={`/guides/${featured.data.slug}/`} class="group block bg-surface-container-low rounded-xl overflow-hidden hover:bg-surface-container-high ghost-border transition-all mb-10">
            <div class="grid grid-cols-1 md:grid-cols-2">
              {featured.data.image && (
                <div class="aspect-video md:aspect-auto md:min-h-[360px] overflow-hidden relative">
                  <img
                    src={featured.data.image}
                    alt={featured.data.imageAlt || featured.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    loading="eager"
                  />
                  <div class="absolute top-4 left-4 flex gap-2">
                    <span class="bg-secondary/90 text-on-secondary text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm backdrop-blur-md">Featured Guide</span>
                    {featured.data.category && (
                      <span class="bg-surface/80 text-on-surface text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm backdrop-blur-md">{featured.data.category}</span>
                    )}
                  </div>
                </div>
              )}
              <div class="p-8 md:p-10 flex flex-col justify-center">
                <div class="flex items-center gap-3 text-xs font-label text-on-surface-variant mb-4">
                  {featured.data.publishedAt && (
                    <time>{new Date(featured.data.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</time>
                  )}
                  {featured.data.author && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                      <span>By {featured.data.author}</span>
                    </>
                  )}
                </div>
                <h2 class="font-headline text-2xl md:text-3xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">
                  {featured.data.title}
                </h2>
                {featured.data.excerpt && (
                  <p class="text-on-surface-variant leading-relaxed mb-6 line-clamp-3">{featured.data.excerpt}</p>
                )}
                <div class="flex items-center gap-2 text-primary font-bold text-sm group-hover:gap-3 transition-all">
                  <span>Read Guide</span>
                  <span class="material-symbols-outlined text-sm">trending_flat</span>
                </div>
              </div>
            </div>
          </a>
        )}

        {/* Guide Grid */}
        {rest.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {rest.map((guide: any) => (
              <ArticleCard article={{ ...guide, collection: "guides" }} />
            ))}
          </div>
        )}
      </>
    ) : (
      /* Empty State */
      <div class="bg-surface-container-low rounded-xl p-12 md:p-16 text-center">
        <span class="material-symbols-outlined text-outline text-5xl mb-6 block">menu_book</span>
        <h2 class="font-headline font-bold text-xl text-on-surface mb-3">Guides Coming Soon</h2>
        <p class="text-on-surface-variant text-lg max-w-md mx-auto leading-relaxed">
          Stay tuned — our editorial team is preparing comprehensive strategy guides and expert insights.
        </p>
      </div>
    )}
  </div>
</BaseLayout>
