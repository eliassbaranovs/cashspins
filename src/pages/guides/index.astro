---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import EditorialByline from "../../components/EditorialByline.astro";
import { buildCanonical } from "../../lib/seo";

let allGuides: Awaited<ReturnType<typeof getCollection>> = [];
try {
  allGuides = await getCollection("guides");
} catch {
  allGuides = [];
}

const guides = allGuides
  .sort(
    (a: any, b: any) =>
      new Date(b.data.published_at).getTime() -
      new Date(a.data.published_at).getTime()
  );

const siteBase = "https://cashspins.online";
const itemListSchema = guides.length > 0
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "CashSpins Casino Guides",
      "description": "In-depth casino strategy, bonus, and responsible-gambling guides from the CashSpins editorial team.",
      "numberOfItems": guides.length,
      "itemListElement": guides.slice(0, 15).map((g: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `${siteBase}/guides/${g.data.slug}/`,
        "name": g.data.title ?? g.data.slug,
      })),
    })
  : undefined;

// Derive category tags — normalize to lowercase to deduplicate across mixed-case tags
const allTags = [...new Set(guides.flatMap((g: any) => (g.data.tags ?? []).map((t: string) => t.toLowerCase())))];
const toTitleCase = (s: string) => s.replace(/\b\w/g, (c: string) => c.toUpperCase());

// Build author lookup map
let authorMap = new Map<string, string>();
try {
  const authors = await getCollection("authors");
  authors.forEach((a: any) => authorMap.set(a.data.slug, a.data.name));
} catch {}
const resolveAuthor = (slug?: string) => slug ? (authorMap.get(slug) ?? slug) : undefined;

const featured = guides[0];
const rest = guides.slice(1);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Guides" },
];
---

<BaseLayout
  title="Casino Guides & Strategy | CashSpins"
  seoTitle="Casino Guides & Strategy 2026 — Expert Tips | CashSpins"
  description="In-depth casino guides covering game strategies, bonus optimization, responsible gambling, and everything you need to play smarter. Written by CashSpins experts."
  canonical={buildCanonical("guides")}
  schemaJsonLd={itemListSchema}
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8 pt-8 pb-20">
    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-4">
        Expert <span class="text-primary">Guides</span>
      </h1>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl leading-relaxed mb-6">
        Comprehensive guides covering game strategies, bonus mechanics, and responsible gambling — written for players who want to play smarter.
      </p>
      <EditorialByline />
    </header>

    {guides.length > 0 ? (
      <>
        {/* Category Filter Pills */}
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-3 mb-10" id="guide-filters">
            <button
              type="button"
              data-tag="all"
              class="filter-pill px-5 py-2 rounded-full text-sm font-bold bg-primary text-on-primary shadow-md transition-all"
            >
              All Guides
            </button>
            {allTags.slice(0, 8).map((tag: string) => (
              <button
                type="button"
                data-tag={tag}
                class="filter-pill px-5 py-2 rounded-full text-sm font-bold bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-all"
              >
                {toTitleCase(tag)}
              </button>
            ))}
          </div>
        )}

        {/* Featured Guide */}
        {featured && (
          <div data-guide-tags={JSON.stringify((featured.data.tags ?? []).map((t: string) => t.toLowerCase()))} class="guide-card mb-10">
            <a href={`/guides/${featured.data.slug}/`} class="group block bg-surface-container-low rounded-xl overflow-hidden hover:bg-surface-container-high ghost-border transition-all">
              <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="relative bg-surface-container aspect-video md:aspect-auto md:min-h-80 overflow-hidden">
                  {featured.data.image ? (
                    <img
                      src={featured.data.image as string}
                      alt={(featured.data.image_alt as string | undefined) || (featured.data.title as string)}
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="eager"
                      fetchpriority="high"
                    />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <span class="material-symbols-outlined text-primary text-5xl">menu_book</span>
                    </div>
                  )}
                  <div class="absolute top-4 left-4 flex gap-2 z-10">
                    <span class="bg-secondary/90 text-on-secondary text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm">Featured Guide</span>
                    {featured.data.category && (
                      <span class="bg-surface/90 backdrop-blur-sm text-on-surface text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm">{featured.data.category}</span>
                    )}
                  </div>
                </div>
                <div class="p-8 md:p-10 flex flex-col justify-center">
                  <div class="flex items-center gap-3 text-xs font-label text-on-surface-variant mb-4">
                    {featured.data.published_at && (
                      <time>{new Date(featured.data.published_at).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</time>
                    )}
                    {featured.data.author_slug && (
                      <>
                        <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                        <span>By {resolveAuthor(featured.data.author_slug)}</span>
                      </>
                    )}
                  </div>
                  <h2 class="font-headline text-2xl md:text-3xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">
                    {featured.data.title}
                  </h2>
                  {featured.data.excerpt && (
                    <p class="text-on-surface-variant leading-relaxed mb-6 line-clamp-3">{featured.data.excerpt}</p>
                  )}
                  <div class="flex items-center gap-2 text-primary font-bold text-sm group-hover:gap-3 transition-all">
                    <span>Read Guide</span>
                    <span class="material-symbols-outlined text-sm">trending_flat</span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        )}

        {/* Guide Grid */}
        {rest.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="guide-grid">
            {rest.map((guide: any) => (
              <div data-guide-tags={JSON.stringify((guide.data.tags ?? []).map((t: string) => t.toLowerCase()))} class="guide-card h-full">
                <ArticleCard article={{ ...guide, data: { ...guide.data, authorName: resolveAuthor(guide.data.author_slug) }, collection: "guides" }} />
              </div>
            ))}
          </div>
        )}

        {/* Empty filter state */}
        <p id="no-guides-msg" class="hidden text-center text-on-surface-variant py-12 text-lg">
          No guides found for this category.
        </p>
      </>
    ) : (
      /* Empty State */
      <div class="bg-surface-container-low rounded-xl p-12 md:p-16 text-center">
        <span class="material-symbols-outlined text-outline text-5xl mb-6 block">menu_book</span>
        <h2 class="font-headline font-bold text-xl text-on-surface mb-3">Guides Coming Soon</h2>
        <p class="text-on-surface-variant text-lg max-w-md mx-auto leading-relaxed">
          Stay tuned — our editorial team is preparing comprehensive strategy guides and expert insights.
        </p>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.guide-card');
  const noMsg = document.getElementById('no-guides-msg');

  function setActive(tag: string) {
    pills.forEach(p => {
      const active = p.dataset.tag === tag;
      p.classList.toggle('bg-primary', active);
      p.classList.toggle('text-on-primary', active);
      p.classList.toggle('shadow-md', active);
      p.classList.toggle('bg-surface-container-high', !active);
      p.classList.toggle('text-on-surface-variant', !active);
    });

    let visible = 0;
    cards.forEach(card => {
      if (tag === 'all') {
        card.style.display = '';
        visible++;
        return;
      }
      const tags: string[] = JSON.parse(card.dataset.guideTags ?? '[]');
      const show = tags.includes(tag);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noMsg) noMsg.classList.toggle('hidden', visible > 0);
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => setActive(pill.dataset.tag ?? 'all'));
  });
</script>
