---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FAQSection from "../../components/FAQSection.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import { buildCanonical, generateArticleSchema, generateFAQSchema } from "../../lib/seo";
import { getRelatedByTags } from "../../lib/collections";

export async function getStaticPaths() {
  let items: Awaited<ReturnType<typeof getCollection>> = [];
  try {
    items = await getCollection("guides");
  } catch {
    return [];
  }
  return items
    .map((item: any) => ({ params: { slug: item.data.slug }, props: { item } }));
}

const { item } = Astro.props;
const d = item.data;
const { Content } = await render(item);

// Related guides
let allGuides: any[] = [];
try {
  allGuides = await getCollection("guides");
} catch {
  allGuides = [];
}
const related = getRelatedByTags(d.tags ?? [], allGuides, d.slug, 3);

// Resolve author
let authorEntry: any = undefined;
try {
  if (d.author_slug) {
    const authors = await getCollection("authors");
    authorEntry = authors.find((a: any) => a.data.slug === d.author_slug);
  }
} catch {}
const authorName = authorEntry?.data?.name ?? d.author_slug;

// Schema
const articleSchema = generateArticleSchema({
  title: d.title,
  description: d.description,
  image: d.image,
  author_name: authorName,
  published_at: d.published_at,
});

const faqSchema =
  d.faqs?.length ? generateFAQSchema(d.faqs) : undefined;

const combinedSchema = faqSchema
  ? `[${articleSchema},${faqSchema}]`
  : articleSchema;


const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Guides", href: "/guides/" },
  { label: d.title },
];

const formattedDate = d.published_at
  ? new Date(d.published_at).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<BaseLayout
  title={d.title}
  seoTitle={d.seo_title}
  description={d.description}
  canonical={buildCanonical(`guides/${d.slug}`)}
  schemaJsonLd={combinedSchema}
  ogType="article"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8 pt-8 pb-20">
    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <!-- Main Content -->
      <article class="lg:col-span-8">
        <!-- Article Header -->
        <header class="mb-10">
          {/* Category badge */}
          {d.category && (
            <span class="inline-block bg-secondary/10 text-secondary text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm mb-4">
              {d.category}
            </span>
          )}

          <h1 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight text-on-surface leading-tight mb-6">
            {d.title}
          </h1>

          {d.excerpt && (
            <p class="text-on-surface-variant text-lg leading-relaxed mb-6">{d.excerpt}</p>
          )}

          {/* Meta line */}
          <div class="flex items-center flex-wrap gap-3 text-sm font-label text-on-surface-variant">
            {authorName && (
              <span class="flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">person</span>
                {authorName}
              </span>
            )}
            {formattedDate && (
              <>
                <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                <time datetime={d.published_at} class="flex items-center gap-1.5">
                  <span class="material-symbols-outlined text-sm">calendar_today</span>
                  {formattedDate}
                </time>
              </>
            )}
          </div>
        </header>

        {/* Featured Image */}
        {d.image && (
          <figure class="mb-10 rounded-xl overflow-hidden bg-surface-container-low">
            <img
              src={d.image}
              alt={d.image_alt || d.title}
              class="w-full h-auto aspect-video object-cover"
              loading="eager"
              fetchpriority="high"
            />
          </figure>
        )}

        {/* Article Body */}
        <div id="guide-content" class="prose prose-invert max-w-none mb-16
          [&_h2]:font-headline [&_h2]:font-bold [&_h2]:text-2xl [&_h2]:text-on-surface [&_h2]:border-b [&_h2]:border-outline-variant/20 [&_h2]:pb-3 [&_h2]:mb-6 [&_h2]:mt-10 [&_h2]:scroll-mt-24
          [&_h3]:font-headline [&_h3]:font-bold [&_h3]:text-xl [&_h3]:text-on-surface [&_h3]:scroll-mt-24
          [&_a]:text-primary [&_a]:hover:underline
          [&_strong]:text-on-surface
          [&_p]:text-on-surface-variant [&_p]:leading-relaxed
          [&_li]:text-on-surface-variant
          [&_blockquote]:border-l-4 [&_blockquote]:border-primary/40 [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-on-surface-variant
          [&_table]:text-sm [&_th]:text-on-surface [&_td]:text-on-surface-variant
          [&_code]:bg-surface-container-high [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm
        ">
          <Content />
        </div>

        {/* FAQs */}
        <div class="mb-12">
          <FAQSection faqs={d.faqs} />
        </div>

        {/* Tags */}
        {d.tags?.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-12 pb-8 border-b border-outline-variant/20">
            {d.tags.map((tag: string) => (
              <span class="bg-surface-container-high text-on-surface-variant text-xs font-label px-3 py-1.5 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Related Content */}
        {related.length > 0 && (
          <RelatedContent
            title="Related Guides"
            items={related.map((r: any) => ({
              slug: r.data.slug,
              collection: "guides",
              data: r.data,
            }))}
          />
        )}
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-24 space-y-8">
          {/* Table of Contents — populated client-side from headings */}
          <div id="toc-container" class="bg-surface-container-low rounded-xl p-6 hidden">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">toc</span>
              In This Guide
            </h3>
            <nav id="toc-nav" aria-label="Table of Contents">
              <ol class="space-y-2 text-sm" id="toc-list"></ol>
            </nav>
          </div>

          {/* Quick Info */}
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">info</span>
              About This Guide
            </h3>
            <dl class="space-y-3 text-sm">
              {authorName && (
                <div class="flex justify-between">
                  <dt class="text-on-surface-variant">Author</dt>
                  <dd class="text-on-surface font-semibold">{authorName}</dd>
                </div>
              )}
              {formattedDate && (
                <div class="flex justify-between">
                  <dt class="text-on-surface-variant">Published</dt>
                  <dd class="text-on-surface font-semibold">{formattedDate}</dd>
                </div>
              )}
              {d.category && (
                <div class="flex justify-between">
                  <dt class="text-on-surface-variant">Category</dt>
                  <dd class="text-on-surface font-semibold">{d.category}</dd>
                </div>
              )}
            </dl>
          </div>

          {/* Responsible Gambling */}
          <div class="bg-surface-container-low rounded-xl p-6 border-t-2 border-error/30">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-error text-xl">warning</span>
              <h3 class="font-headline font-bold text-sm text-on-surface">Responsible Gambling</h3>
            </div>
            <p class="text-on-surface-variant text-xs leading-relaxed">
              18+ only. Gambling can be addictive — please play responsibly.
              <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">GambleAware</a> ·
              <a href="https://www.gamblingtherapy.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">Gambling Therapy</a>
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>

  {/* Client-side TOC generation */}
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const content = document.getElementById("guide-content");
      const tocContainer = document.getElementById("toc-container");
      const tocList = document.getElementById("toc-list");
      if (!content || !tocContainer || !tocList) return;

      const headings = content.querySelectorAll("h2, h3");
      if (headings.length < 2) return;

      headings.forEach((heading, i) => {
        const id = heading.id || `heading-${i}`;
        heading.id = id;

        const li = document.createElement("li");
        const a = document.createElement("a");
        a.href = `#${id}`;
        a.textContent = heading.textContent || "";
        a.className =
          heading.tagName === "H3"
            ? "block pl-4 text-on-surface-variant hover:text-primary transition-colors"
            : "block font-semibold text-on-surface hover:text-primary transition-colors";
        li.appendChild(a);
        tocList.appendChild(li);
      });

      tocContainer.classList.remove("hidden");
    });
  </script>
</BaseLayout>
