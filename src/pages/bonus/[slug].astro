---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTAButton from "../../components/CTAButton.astro";
import ProsCons from "../../components/ProsCons.astro";
import FAQSection from "../../components/FAQSection.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import { buildCanonical, generateArticleSchema, generateFAQSchema } from "../../lib/seo";
import { getRelatedByTags } from "../../lib/collections";

export async function getStaticPaths() {
  const posts = await getCollection("bonuses");
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);

// Related bonuses
const allBonuses = await getCollection("bonuses");
const related = getRelatedByTags(d.tags ?? [], allBonuses, d.slug, 3);

// Author
let authorEntry: any = undefined;
try {
  if (d.authorSlug) {
    const authors = await getCollection("authors");
    authorEntry = authors.find((a) => a.data.slug === d.authorSlug);
  }
} catch {}

// Schema
const articleSchema = generateArticleSchema({
  title: d.title,
  description: d.description,
  image: d.image,
  author: d.author,
  publishedAt: d.publishedAt,
  updatedAt: d.updatedAt,
});

const faqSchema =
  d.faqs?.length ? generateFAQSchema(d.faqs) : undefined;

const combinedSchema = faqSchema
  ? `[${articleSchema},${faqSchema}]`
  : articleSchema;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Bonuses", href: "/bonus/" },
  { label: d.title },
];

const formattedDate = d.publishedAt
  ? new Date(d.publishedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

// Payment methods
const depositArr = d.depositMethods?.split("|").map((s: string) => s.trim()) ?? [];
const withdrawalArr = d.withdrawalMethods?.split("|").map((s: string) => s.trim()) ?? [];
---

<BaseLayout
  title={d.title}
  seoTitle={d.seoTitle}
  description={d.description}
  image={d.image}
  imageAlt={d.imageAlt}
  canonical={d.canonical || buildCanonical(`bonus/${d.slug}`)}
  robots={d.robots}
  schemaJsonLd={combinedSchema}
  noIndex={d.noIndex}
  ogType="article"
>
  <div class="max-w-screen-2xl mx-auto px-8 pt-8">
    <!-- Breadcrumbs -->
    <div class="mb-6">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Hero Section -->
    <div class="bg-surface-container-low rounded-xl p-6 md:p-10 mb-10">
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
        <!-- Casino Brand -->
        <div class="flex flex-col items-center gap-3 shrink-0">
          {d.logo ? (
            <img
              src={d.logo}
              alt={`${d.casinoName} logo`}
              width="80"
              height="80"
              class="w-20 h-20 rounded-xl bg-surface-container-lowest object-contain p-2"
            />
          ) : (
            <div class="w-20 h-20 rounded-xl bg-surface-container-lowest flex items-center justify-center">
              <span class="material-symbols-outlined text-outline text-3xl">redeem</span>
            </div>
          )}
          {d.casinoName && (
            <span class="text-on-surface-variant text-sm font-label text-center">{d.casinoName}</span>
          )}
        </div>

        <!-- Bonus Details -->
        <div class="flex-1 min-w-0">
          <h1 class="font-headline text-2xl md:text-4xl font-extrabold text-primary mb-4 tracking-tight leading-tight">
            {d.bonus_title ?? d.title}
          </h1>

          <!-- Key Terms -->
          <div class="flex flex-wrap gap-4 md:gap-6 mb-6">
            {d.bonus_percentage && (
              <div class="text-center">
                <span class="material-symbols-outlined text-primary text-lg mb-1 block">percent</span>
                <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">Match</span>
                <span class="block text-lg font-bold text-on-surface">{d.bonus_percentage}%</span>
              </div>
            )}
            {d.max_bonus && (
              <div class="text-center">
                <span class="material-symbols-outlined text-primary text-lg mb-1 block">savings</span>
                <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">Max Bonus</span>
                <span class="block text-lg font-bold text-on-surface">{d.max_bonus}</span>
              </div>
            )}
            {d.wagering && (
              <div class="text-center">
                <span class="material-symbols-outlined text-primary text-lg mb-1 block">calculate</span>
                <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">Wagering</span>
                <span class="block text-lg font-bold text-on-surface">{d.wagering}</span>
              </div>
            )}
            {(d.min_deposit || d.bonus_min_deposit) && (
              <div class="text-center">
                <span class="material-symbols-outlined text-primary text-lg mb-1 block">account_balance_wallet</span>
                <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">Min Deposit</span>
                <span class="block text-lg font-bold text-on-surface">{d.bonus_min_deposit ?? d.min_deposit}</span>
              </div>
            )}
            {d.free_spins && (
              <div class="text-center">
                <span class="material-symbols-outlined text-primary text-lg mb-1 block">confirmation_number</span>
                <span class="block text-xs font-label text-on-surface-variant uppercase tracking-wider">Free Spins</span>
                <span class="block text-lg font-bold text-on-surface">{d.free_spins}</span>
              </div>
            )}
          </div>

          {/* Meta */}
          {(formattedDate || d.author) && (
            <div class="flex flex-wrap items-center gap-2 text-xs font-label text-on-surface-variant">
              {formattedDate && (
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">calendar_today</span>
                  <time datetime={d.publishedAt}>{formattedDate}</time>
                </div>
              )}
              {d.updatedAt && d.updatedAt !== d.publishedAt && (
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">update</span>
                  <span>Updated: {new Date(d.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
                </div>
              )}
              {d.author && (
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">person</span>
                  <span>{d.author}</span>
                </div>
              )}
            </div>
          )}
        </div>

        <!-- CTA -->
        <div class="flex flex-col gap-3 shrink-0 w-full md:w-auto">
          {d.casino && (
            <CTAButton href={`/go/${d.casino}/`} label="Claim Bonus" size="lg" sponsored />
          )}
          {d.casino && (
            <a
              href={`/casinos/${d.casino}/`}
              class="text-on-surface-variant text-sm text-center hover:text-primary transition-colors"
            >
              Full Casino Review
              <span class="material-symbols-outlined text-sm align-middle">arrow_forward</span>
            </a>
          )}
        </div>
      </div>
    </div>

    {d.excerpt && (
      <div class="bg-surface-container-lowest rounded-xl p-6 mb-10 border-l-4 border-primary/30">
        <p class="text-on-surface-variant leading-relaxed italic">{d.excerpt}</p>
      </div>
    )}

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 pb-20">
      <!-- Main Content -->
      <div class="lg:col-span-8 space-y-12">
        {/* Cover Image */}
        {d.image && (
          <div class="rounded-xl overflow-hidden">
            <img
              src={d.image}
              alt={d.imageAlt ?? `${d.casinoName} bonus`}
              width={d.imageWidth ?? 1792}
              height={d.imageHeight ?? 1024}
              class="w-full h-auto object-cover"
              loading="eager"
            />
          </div>
        )}

        {/* Pros & Cons */}
        <ProsCons pros={d.pros} cons={d.cons} />

        {/* Article Body */}
        <div class="prose prose-invert max-w-none
          [&_h2]:font-headline [&_h2]:font-bold [&_h2]:text-2xl [&_h2]:text-on-surface [&_h2]:border-b [&_h2]:border-outline-variant/20 [&_h2]:pb-3 [&_h2]:mb-6
          [&_h3]:font-headline [&_h3]:font-bold [&_h3]:text-xl [&_h3]:text-on-surface
          [&_a]:text-primary [&_a]:hover:underline
          [&_strong]:text-on-surface
          [&_p]:text-on-surface-variant [&_p]:leading-relaxed
          [&_li]:text-on-surface-variant
          [&_table]:text-sm [&_th]:text-on-surface [&_td]:text-on-surface-variant
        ">
          <Content />
        </div>

        {/* FAQs */}
        <FAQSection faqs={d.faqs} />

        {/* Author Card — E-E-A-T signal */}
        {(d.author || authorEntry) && (
          <section class="bg-surface-container-low rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-start">
            {authorEntry?.data?.avatar && (
              <img
                src={authorEntry.data.avatar}
                alt={authorEntry.data.name ?? d.author}
                class="w-16 h-16 rounded-full object-cover shrink-0"
                loading="lazy"
                width="64"
                height="64"
              />
            )}
            <div>
              <p class="text-xs font-label text-on-surface-variant uppercase tracking-wider mb-1">Reviewed by</p>
              <p class="font-headline font-bold text-on-surface text-lg">
                {authorEntry ? (
                  <a href={`/team/${authorEntry.data.slug}/`} class="hover:text-primary transition-colors">{authorEntry.data.name}</a>
                ) : d.author}
              </p>
              {authorEntry?.data?.role && (
                <p class="text-secondary text-xs font-bold mt-0.5">{authorEntry.data.role}</p>
              )}
              {authorEntry?.data?.bio && (
                <p class="text-on-surface-variant text-sm mt-2 line-clamp-2">{authorEntry.data.bio}</p>
              )}
            </div>
          </section>
        )}

        {/* Tags — internal linking */}
        {d.tags && d.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {d.tags.map((tag: string) => (
              <span class="bg-surface-container-high text-on-surface-variant text-xs font-label px-3 py-1.5 rounded-full flex items-center gap-1">
                <span class="material-symbols-outlined text-xs">sell</span>
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Related Content */}
        {related.length > 0 && (
          <RelatedContent
            title="Related Bonus Offers"
            items={related.map((r) => ({
              slug: r.data.slug,
              collection: "bonus",
              data: r.data,
            }))}
            type="casino"
          />
        )}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-8">
        {/* All Bonus Offers */}
        {d.bonuses?.length && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-5 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">redeem</span>
              All Current Offers
            </h3>
            <div class="space-y-4">
              {d.bonuses.map((bonus: { name: string; type?: string; wagering?: string; min_deposit?: string; max_cashout?: string; free_spins?: string | number; expiry?: string }) => (
                <div class="bg-surface-container-lowest rounded-lg p-4">
                  <div class="flex items-start justify-between gap-2 mb-2">
                    <p class="font-headline font-bold text-sm text-on-surface">{bonus.name}</p>
                    {bonus.type && (
                      <span class="inline-block bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-sm shrink-0">
                        {bonus.type}
                      </span>
                    )}
                  </div>
                  <div class="space-y-1 text-xs text-on-surface-variant">
                    {bonus.wagering && (
                      <div class="flex justify-between"><span>Wagering</span><span class="text-on-surface font-semibold">{bonus.wagering}</span></div>
                    )}
                    {bonus.min_deposit && (
                      <div class="flex justify-between"><span>Min Deposit</span><span class="text-on-surface font-semibold">{bonus.min_deposit}</span></div>
                    )}
                    {bonus.free_spins && (
                      <div class="flex justify-between"><span>Free Spins</span><span class="text-secondary font-semibold">{bonus.free_spins}</span></div>
                    )}
                    {bonus.max_cashout && (
                      <div class="flex justify-between"><span>Max Cashout</span><span class="text-on-surface font-semibold">{bonus.max_cashout}</span></div>
                    )}
                    {bonus.expiry && (
                      <div class="flex justify-between"><span>Expiry</span><span class="text-on-surface font-semibold">{bonus.expiry}</span></div>
                    )}
                  </div>
                  {d.casino && (
                    <div class="mt-3">
                      <CTAButton href={`/go/${d.casino}/`} label="Claim" size="sm" sponsored />
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Payment Methods */}
        {(depositArr.length > 0 || withdrawalArr.length > 0) && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-5 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">account_balance_wallet</span>
              Payment Methods
            </h3>
            {depositArr.length > 0 && (
              <div class="mb-4">
                <p class="text-xs font-label text-on-surface-variant uppercase tracking-wider mb-2">Deposit</p>
                <div class="flex flex-wrap gap-2">
                  {depositArr.map((method: string) => (
                    <span class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md">{method}</span>
                  ))}
                </div>
              </div>
            )}
            {withdrawalArr.length > 0 && (
              <div>
                <p class="text-xs font-label text-on-surface-variant uppercase tracking-wider mb-2">Withdrawal</p>
                <div class="flex flex-wrap gap-2">
                  {withdrawalArr.map((method: string) => (
                    <span class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md">{method}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* Quick Info */}
        <div class="bg-surface-container-low rounded-xl p-6">
          <h3 class="font-headline font-bold text-lg text-on-surface mb-5 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">info</span>
            Quick Info
          </h3>
          <dl class="space-y-3 text-sm">
            {d.casinoName && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant">Casino</dt>
                <dd class="text-on-surface font-semibold">{d.casinoName}</dd>
              </div>
            )}
            {d.bonus_code && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant">Bonus Code</dt>
                <dd class="text-primary font-bold">{d.bonus_code}</dd>
              </div>
            )}
            {d.wagering && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant">Wagering</dt>
                <dd class="text-on-surface font-semibold">{d.wagering}</dd>
              </div>
            )}
            {d.ourRating != null && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant">Our Rating</dt>
                <dd class="text-primary font-bold">{d.ourRating}/10</dd>
              </div>
            )}
          </dl>
        </div>

        {/* Responsible Gambling */}
        <div class="bg-surface-container-low rounded-xl p-6 border-t-2 border-error/30">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-error text-xl">warning</span>
            <h3 class="font-headline font-bold text-sm text-on-surface">Responsible Gambling</h3>
          </div>
          <p class="text-on-surface-variant text-xs leading-relaxed">
            18+ only. Bonus terms and conditions apply. Gambling can be addictive — please play responsibly.
            <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">GambleAware</a> ·
            <a href="https://www.gamblingtherapy.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">Gambling Therapy</a>
          </p>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
