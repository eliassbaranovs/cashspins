---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BonusCard from "../../components/BonusCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const allBonuses = await getCollection("bonuses");
const bonuses = allBonuses
  .sort(
    (a, b) =>
      new Date(b.data.published_at).getTime() -
      new Date(a.data.published_at).getTime()
  );

// Bonus-type taxonomy — maps normalized tag keywords to user-facing filter labels.
// Order matters: higher-priority types (rarer / more differentiating) appear first.
const BONUS_TYPES: { key: string; label: string; matchers: string[] }[] = [
  { key: "no-deposit", label: "No Deposit", matchers: ["no deposit", "no-deposit"] },
  { key: "free-spins", label: "Free Spins", matchers: ["free spins"] },
  { key: "cashback",   label: "Cashback",   matchers: ["cashback"] },
  { key: "rakeback",   label: "Rakeback",   matchers: ["rakeback"] },
  { key: "vip",        label: "VIP / Loyalty", matchers: ["loyalty", "vip"] },
  { key: "welcome",    label: "Welcome",    matchers: ["welcome"] },
  { key: "crypto",     label: "Crypto",     matchers: ["crypto"] },
];

function typesForBonus(tags: string[] = []): string[] {
  const norm = tags.map(t => t.toLowerCase());
  const keys = new Set<string>();
  for (const t of BONUS_TYPES) {
    if (t.matchers.some(m => norm.some(n => n.includes(m)))) keys.add(t.key);
  }
  return [...keys];
}

// Only surface filter pills for types that at least one bonus matches.
const presentTypeKeys = new Set(bonuses.flatMap(b => typesForBonus(b.data.tags ?? [])));
const activeTypes = BONUS_TYPES.filter(t => presentTypeKeys.has(t.key));

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Bonuses" },
];
---

<BaseLayout
  title="Best Casino Bonuses 2026 | CashSpins"
  seoTitle="Best Casino Bonuses 2026 — Top Welcome Offers & Free Spins"
  description="Compare the best casino bonuses in 2026. Welcome bonuses, no-deposit free spins, cashback deals — ranked and reviewed by CashSpins experts."
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8 pt-8 pb-20">
    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Header -->
    <header class="mb-12">
      <h1 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-on-surface mb-4">
        Casino Bonuses & <span class="text-primary">Promotions</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed">
        Curated bonus offers verified by our editorial team. Welcome packages, free spins, no-deposit deals, and cashback promotions — all with transparent terms.
      </p>
    </header>

    {/* Summary line */}
    {bonuses.length > 0 && (
      <p class="text-sm text-on-surface-variant mb-6">
        <span class="text-on-surface font-semibold">{bonuses.length}</span> verified offers across
        <span class="text-on-surface font-semibold"> {new Set(bonuses.map(b => b.data.casino_slug || b.data.slug)).size}</span> casinos — independently reviewed, terms transparent.
      </p>
    )}

    {/* Bonus-type Filter Pills */}
    {activeTypes.length > 0 && (
      <div class="flex flex-wrap gap-3 mb-10" id="bonus-filters">
        <button
          type="button"
          data-type="all"
          class="filter-pill px-5 py-2 rounded-full text-sm font-bold bg-primary text-on-primary shadow-md transition-all"
        >
          All Bonuses
        </button>
        {activeTypes.map(t => (
          <button
            type="button"
            data-type={t.key}
            class="filter-pill px-5 py-2 rounded-full text-sm font-bold bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-all"
          >
            {t.label}
          </button>
        ))}
      </div>
    )}

    <!-- Bonus List -->
    {bonuses.length > 0 ? (
      <>
      <div class="space-y-5 mb-4" id="bonus-list">
        {bonuses.map((bonus) => (
          <div data-bonus-types={JSON.stringify(typesForBonus(bonus.data.tags ?? []))} class="bonus-card-wrap">
            <BonusCard bonus={bonus} />
          </div>
        ))}
      </div>
      <p id="no-bonus-msg" class="hidden text-center text-on-surface-variant py-12 text-lg mb-12">
        No bonuses found for this category.
      </p>
      </>
    ) : (
      <div class="bg-surface-container-low rounded-xl p-12 text-center mb-16">
        <span class="material-symbols-outlined text-outline text-4xl mb-4 block">redeem</span>
        <p class="text-on-surface-variant text-lg">
          No bonuses published yet. Check back soon for exclusive offers.
        </p>
      </div>
    )}

    <!-- SEO Text Block -->
    <section class="bg-surface-container-low rounded-xl p-8 md:p-12 mb-10">
      <h2 class="font-headline font-bold text-2xl text-on-surface mb-4">How We Rate Casino Bonuses</h2>
      <div class="text-on-surface-variant leading-relaxed space-y-4 max-w-3xl">
        <p>
          Every bonus listed on CashSpins is independently verified by our editorial team. We evaluate welcome packages, free spin offers, no-deposit bonuses, and reload promotions based on wagering requirements, maximum cashout limits, game restrictions, and overall value.
        </p>
        <p>
          Our methodology prioritises transparency — we break down the fine print so you can make informed decisions. Bonuses are ranked by a combination of bonus value, fair wagering terms, and the reliability of the casino operator.
        </p>
        <p>
          Always read the full terms and conditions before claiming any bonus. Gambling should be fun — if you feel it is becoming a problem, please visit <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">GambleAware</a> or <a href="https://www.gamblingtherapy.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">Gambling Therapy</a>.
        </p>
      </div>
    </section>

    <!-- Responsible gambling note -->
    <div class="text-center text-xs text-on-surface-variant/60 py-4">
      <strong>18+ only.</strong> Bonus terms apply. Gambling can be addictive.
      <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="hover:text-primary transition-colors">GambleAware</a> ·
      <a href="https://www.gamblingtherapy.org" rel="noopener noreferrer" target="_blank" class="hover:text-primary transition-colors">Gambling Therapy</a>
    </div>
  </div>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('#bonus-filters .filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.bonus-card-wrap');
  const noMsg = document.getElementById('no-bonus-msg');

  function setActive(type: string) {
    pills.forEach(p => {
      const active = p.dataset.type === type;
      p.classList.toggle('bg-primary', active);
      p.classList.toggle('text-on-primary', active);
      p.classList.toggle('shadow-md', active);
      p.classList.toggle('bg-surface-container-high', !active);
      p.classList.toggle('text-on-surface-variant', !active);
    });

    let visible = 0;
    cards.forEach(card => {
      if (type === 'all') {
        card.style.display = '';
        visible++;
        return;
      }
      const types: string[] = JSON.parse(card.dataset.bonusTypes ?? '[]');
      const show = types.includes(type);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noMsg) noMsg.classList.toggle('hidden', visible > 0);
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => setActive(pill.dataset.type ?? 'all'));
  });
</script>
