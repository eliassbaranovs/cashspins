---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RatingStars from "../../components/RatingStars.astro";
import RatingBadge from "../../components/RatingBadge.astro";
import CTAButton from "../../components/CTAButton.astro";
import ProsCons from "../../components/ProsCons.astro";
import FAQSection from "../../components/FAQSection.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import { buildCanonical, generateReviewSchema, generateFAQSchema } from "../../lib/seo";
import { getRelatedByTags } from "../../lib/collections";

export async function getStaticPaths() {
  const casinos = await getCollection("casinos");
  return casinos
    .filter((c) => !c.data.draft)
    .map((casino) => ({
      params: { slug: casino.data.slug },
      props: { casino },
    }));
}

const { casino } = Astro.props;
const d = casino.data;
const { Content } = await render(casino);

// Parse pipe-delimited fields
const depositArr = d.depositMethods?.split("|").map((s: string) => s.trim()).filter(Boolean) ?? [];
const withdrawalArr = d.withdrawalMethods?.split("|").map((s: string) => s.trim()).filter(Boolean) ?? [];
const providersArr = d.gameProviders?.split("|").map((s: string) => s.trim()).filter(Boolean) ?? [];
const currenciesArr = d.currencies?.split("|").map((s: string) => s.trim()).filter(Boolean) ?? [];

// Related casinos
const allCasinos = await getCollection("casinos");
const related = getRelatedByTags(d.tags ?? [], allCasinos.filter((c) => !c.data.draft), d.slug, 3);

// Author
let authorEntry: any = undefined;
try {
  if (d.authorSlug) {
    const authors = await getCollection("authors");
    authorEntry = authors.find((a) => a.data.slug === d.authorSlug);
  }
} catch {}

// SEO schemas
const canonical = buildCanonical(`casinos/${d.slug}`);
const reviewSchema = generateReviewSchema({
  title: d.title,
  description: d.description ?? "",
  ourRating: d.ourRating,
  image: d.image,
  author: d.author,
  publishedAt: d.publishedAt,
  slug: d.slug,
});

const faqSchema = d.faqs?.length ? generateFAQSchema(d.faqs) : undefined;

// Combine schemas
const schemas: string[] = [reviewSchema];
if (faqSchema) schemas.push(faqSchema);
const combinedSchema = `[${schemas.join(",")}]`;
---

<BaseLayout
  title={d.title}
  seoTitle={d.seoTitle}
  description={d.description}
  image={d.image}
  imageAlt={d.imageAlt}
  canonical={canonical}
  robots={d.robots}
  schemaJsonLd={d.schemaJsonLd || combinedSchema}
  noIndex={d.noIndex}
  ogType="article"
>
  <div class="max-w-screen-2xl mx-auto px-4 md:px-8 pt-8 pb-20">

    {/* ───────────────── HERO HEADER ───────────────── */}
    <header class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">

      {/* Left column */}
      <div class="lg:col-span-8 flex flex-col justify-center">
        {/* Breadcrumbs */}
        <div class="mb-6">
          <Breadcrumbs
            items={[
              { label: "Home", href: "/" },
              { label: "Casino Reviews", href: "/casinos/" },
              { label: d.casinoName ?? d.title },
            ]}
          />
        </div>

        {/* Logo + heading group */}
        <div class="flex items-center gap-6 mb-6">
          {d.logo ? (
            <div class="w-24 h-24 bg-surface-container-high rounded-xl flex items-center justify-center p-4 shadow-xl border border-outline-variant/20 overflow-hidden shrink-0">
              <img
                src={d.logo}
                alt={`${d.casinoName} logo`}
                class="w-full h-full object-contain"
                loading="eager"
                width="64"
                height="64"
              />
            </div>
          ) : (
            <div class="w-24 h-24 bg-surface-container-high rounded-xl flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-outline text-4xl">casino</span>
            </div>
          )}
          <div>
            {/* Verified badge */}
            {d.ourRating != null && d.ourRating >= 8 && (
              <div class="flex items-center gap-3 mb-2">
                <span class="bg-secondary-container/20 text-secondary text-[10px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-sm flex items-center gap-1">
                  <span class="material-symbols-outlined text-[12px]" style="font-variation-settings: 'FILL' 1;">verified</span> Verified Expert Choice
                </span>
              </div>
            )}
            {d.lastVerified && (
              <div class="flex items-center gap-1.5 mt-1">
                <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                <span class="text-xs text-on-surface-variant">Last verified: {new Date(d.lastVerified).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
              </div>
            )}

            <h1 class="text-4xl sm:text-5xl md:text-6xl font-headline font-extrabold tracking-tighter text-on-surface mb-2">
              {d.casinoName ?? d.title}
            </h1>

            {/* Rating row */}
            <div class="flex items-center gap-4 text-on-surface-variant flex-wrap">
              {d.ourRating != null && (
                <>
                  <RatingStars rating={d.ourRating} />
                  <span class="font-semibold text-lg text-on-surface">{d.ourRating.toFixed(1)} / 10</span>
                  <span class="text-outline-variant">|</span>
                  <span class="text-sm">Based on expert review</span>
                </>
              )}
            </div>

            {/* Dates — freshness signal for Google */}
            <div class="flex items-center gap-3 mt-3 text-xs text-on-surface-variant font-label">
              {d.publishedAt && (
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">calendar_today</span>
                  <span>Published: <time datetime={d.publishedAt}>{new Date(d.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time></span>
                </div>
              )}
              {d.updatedAt && d.updatedAt !== d.publishedAt && (
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">update</span>
                  <span>Updated: <time datetime={d.updatedAt}>{new Date(d.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time></span>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Right column — Bonus CTA card */}
      <div class="lg:col-span-4">
        <div class="bg-surface-container-low rounded-xl p-8 relative overflow-hidden flex flex-col items-center text-center shadow-2xl group transition-all duration-500 hover:bg-surface-container">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-50 pointer-events-none"></div>

          <p class="text-on-surface-variant font-label font-bold tracking-widest uppercase text-xs mb-4">
            Exclusive Welcome Bonus
          </p>

          {d.bonus_title && (
            <h2 class="text-primary text-3xl sm:text-4xl font-headline font-extrabold tracking-tighter mb-2">
              {d.bonus_title}
            </h2>
          )}

          {d.wagering && (
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Wagering: {d.wagering}. T&Cs apply.
            </p>
          )}

          {!d.wagering && (
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              T&Cs apply.
            </p>
          )}

          <div class="w-full">
            <CTAButton
              href={`/go/${d.slug}/`}
              label="Claim Bonus Now"
              variant="primary"
              size="lg"
              sponsored={true}
              ariaLabel={`Claim bonus at ${d.casinoName ?? d.title}`}
            />
          </div>

          <p class="mt-4 text-[10px] text-outline opacity-60">
            18+ | Play Responsibly | New Customers Only
          </p>
        </div>
      </div>
    </header>

    {/* ───────────────── QUICK STATS GRID ───────────────── */}
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {d.cryptoWithdrawalSpeedMinutes != null && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">speed</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Payout Speed</p>
          <p class="font-bold text-on-surface">~{d.cryptoWithdrawalSpeedMinutes} min</p>
        </div>
      )}

      {d.licences && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-secondary/20">
          <span class="material-symbols-outlined text-secondary mb-3">gavel</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Licensing</p>
          <p class="font-bold text-on-surface text-sm">{d.licences}</p>
        </div>
      )}

      {d.game_count != null && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-tertiary/20">
          <span class="material-symbols-outlined text-tertiary mb-3">casino</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Total Games</p>
          <p class="font-bold text-on-surface">{d.game_count.toLocaleString()}+ Titles</p>
        </div>
      )}

      {d.min_deposit && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">savings</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Min. Deposit</p>
          <p class="font-bold text-on-surface">{d.min_deposit}</p>
        </div>
      )}

      {/* Fallback stats when crypto speed is missing — show established/operator instead */}
      {d.cryptoWithdrawalSpeedMinutes == null && d.established && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">history</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Established</p>
          <p class="font-bold text-on-surface">{d.established}</p>
        </div>
      )}

      {!d.min_deposit && d.company && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">apartment</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Operator</p>
          <p class="font-bold text-on-surface text-sm">{d.company}</p>
        </div>
      )}
    </section>

    {/* Cover Image */}
    {d.image && (
      <div class="mb-16 rounded-xl overflow-hidden">
        <img
          src={d.image}
          alt={d.imageAlt ?? `${d.casinoName ?? d.title} review`}
          width={d.imageWidth ?? 1792}
          height={d.imageHeight ?? 1024}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    )}

    {/* ───────────────── TWO-COLUMN LAYOUT ───────────────── */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      {/* Main content */}
      <div class="lg:col-span-8 space-y-16">

        {/* Pros & Cons */}
        <ProsCons pros={d.pros} cons={d.cons} />

        {/* Article body */}
        <article class="prose prose-invert max-w-none text-on-surface-variant leading-relaxed">
          <Content />
        </article>

        {/* Author Card — E-E-A-T signal */}
        {(d.author || authorEntry) && (
          <section class="bg-surface-container-low rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-start">
            {authorEntry?.data?.avatar && (
              <img
                src={authorEntry.data.avatar}
                alt={authorEntry.data.name ?? d.author}
                class="w-16 h-16 rounded-full object-cover shrink-0"
                loading="lazy"
                width="64"
                height="64"
              />
            )}
            <div>
              <p class="text-xs font-label text-on-surface-variant uppercase tracking-wider mb-1">Reviewed by</p>
              <p class="font-headline font-bold text-on-surface text-lg">
                {authorEntry ? (
                  <a href={`/team/${authorEntry.data.slug}/`} class="hover:text-primary transition-colors">{authorEntry.data.name}</a>
                ) : d.author}
              </p>
              {authorEntry?.data?.role && (
                <p class="text-secondary text-xs font-bold mt-0.5">{authorEntry.data.role}</p>
              )}
              {authorEntry?.data?.bio && (
                <p class="text-on-surface-variant text-sm mt-2 line-clamp-2">{authorEntry.data.bio}</p>
              )}
              {authorEntry?.data?.expertise && authorEntry.data.expertise.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {authorEntry.data.expertise.map((tag: string) => (
                    <span class="bg-surface-container-highest text-on-surface-variant text-[10px] px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </section>
        )}

        {/* Tags — internal linking */}
        {d.tags && d.tags.length > 0 && (
          <section>
            <div class="flex flex-wrap gap-2">
              {d.tags.map((tag: string) => (
                <span class="bg-surface-container-high text-on-surface-variant text-xs font-label px-3 py-1.5 rounded-full flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs">sell</span>
                  {tag}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* Screenshots Gallery */}
        {d.screenshots && d.screenshots.length > 0 && (
          <section>
            <h2 class="font-headline font-bold text-2xl text-on-surface mb-6 flex items-center gap-3">
              <span class="material-symbols-outlined text-secondary">photo_library</span>
              Screenshots
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {d.screenshots.map((s: any) => (
                <div class="rounded-xl overflow-hidden bg-surface-container-low">
                  <img
                    src={s.url}
                    alt={s.alt ?? `${d.casinoName} screenshot`}
                    loading="lazy"
                    width="640"
                    height="360"
                    class="w-full aspect-video object-cover hover:scale-105 transition-transform duration-500"
                  />
                  {s.alt && (
                    <p class="p-3 text-xs text-on-surface-variant">{s.alt}</p>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* FAQ */}
        {d.faqs && d.faqs.length > 0 && (
          <FAQSection faqs={d.faqs} />
        )}
      </div>

      {/* Sidebar */}
      <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-24">

        {/* All Bonuses */}
        {d.bonuses && d.bonuses.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">redeem</span>
              All Bonuses
            </h3>
            <div class="space-y-4">
              {d.bonuses.map((bonus: any) => (
                <div class="border-b border-outline-variant/10 pb-4 last:border-b-0 last:pb-0">
                  {bonus.type && (
                    <span class="inline-block px-2 py-0.5 bg-secondary-container/20 text-secondary text-[10px] font-bold uppercase tracking-widest rounded-sm mb-1.5">
                      {bonus.type}
                    </span>
                  )}
                  <p class="text-primary font-headline font-extrabold text-sm mb-1">{bonus.name}</p>
                  <ul class="text-xs text-on-surface-variant space-y-0.5">
                    {bonus.wagering && <li>Wagering: {bonus.wagering}</li>}
                    {bonus.min_deposit && <li>Min deposit: {bonus.min_deposit}</li>}
                    {bonus.expiry && <li>Expiry: {bonus.expiry}</li>}
                    {bonus.free_spins && <li>Free spins: {bonus.free_spins}</li>}
                  </ul>
                </div>
              ))}
            </div>
            <div class="mt-4">
              <CTAButton
                href={`/go/${d.slug}/`}
                label="Claim Bonus"
                variant="primary"
                size="md"
                sponsored={true}
                ariaLabel={`Claim bonus at ${d.casinoName ?? d.title}`}
              />
            </div>
          </div>
        )}

        {/* Accepted Cryptos */}
        {d.acceptedCryptos && d.acceptedCryptos.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">currency_bitcoin</span>
              Accepted Crypto
            </h3>
            <div class="flex flex-wrap gap-2">
              {d.acceptedCryptos.map((crypto: string) => (
                <span class="px-3 py-1 bg-surface-container-lowest rounded-full text-xs font-label text-on-surface-variant">
                  {crypto}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* Payment Methods */}
        {(depositArr.length > 0 || withdrawalArr.length > 0) && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">account_balance_wallet</span>
              Payment Methods
            </h3>
            {depositArr.length > 0 && (
              <div class="mb-4">
                <p class="text-[10px] text-outline font-bold uppercase tracking-widest mb-2">Deposit</p>
                <ul class="text-sm text-on-surface-variant space-y-1">
                  {depositArr.map((m: string) => (
                    <li class="flex items-center gap-2">
                      <span class="text-outline text-xs">&#183;</span>
                      {m}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {withdrawalArr.length > 0 && (
              <div>
                <p class="text-[10px] text-outline font-bold uppercase tracking-widest mb-2">Withdrawal</p>
                <ul class="text-sm text-on-surface-variant space-y-1">
                  {withdrawalArr.map((m: string) => (
                    <li class="flex items-center gap-2">
                      <span class="text-outline text-xs">&#183;</span>
                      {m}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )}

        {/* Currencies */}
        {currenciesArr.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">payments</span>
              Currencies
            </h3>
            <div class="flex flex-wrap gap-2">
              {currenciesArr.map((c: string) => (
                <span class="px-3 py-1 bg-surface-container-lowest rounded-full text-xs font-label text-on-surface-variant">{c}</span>
              ))}
            </div>
          </div>
        )}

        {/* Game Providers */}
        {providersArr.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">sports_esports</span>
              Game Providers
            </h3>
            <div class="flex flex-wrap gap-1.5 max-h-48 overflow-y-auto">
              {providersArr.slice(0, 20).map((p: string) => (
                <span class="px-2 py-0.5 bg-surface-container-lowest rounded text-xs text-on-surface-variant">
                  {p}
                </span>
              ))}
              {providersArr.length > 20 && (
                <span class="px-2 py-0.5 text-xs text-outline">
                  +{providersArr.length - 20} more
                </span>
              )}
            </div>
          </div>
        )}

        {/* Key Info */}
        <div class="bg-surface-container-low rounded-xl p-6">
          <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-secondary">info</span>
            Key Info
          </h3>
          <dl class="space-y-3 text-sm">
            {d.established && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">history</span>
                  Established
                </dt>
                <dd class="text-on-surface font-semibold">{d.established}</dd>
              </div>
            )}
            {d.company && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">apartment</span>
                  Operator
                </dt>
                <dd class="text-on-surface font-semibold">{d.company}</dd>
              </div>
            )}
            {d.casino_type && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">category</span>
                  Type
                </dt>
                <dd class="text-on-surface font-semibold">{d.casino_type}</dd>
              </div>
            )}
            {d.wagering && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">calculate</span>
                  Wagering
                </dt>
                <dd class="text-on-surface font-semibold">{d.wagering}</dd>
              </div>
            )}
            {d.vip_program !== undefined && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">workspace_premium</span>
                  VIP Program
                </dt>
                <dd class="text-on-surface font-semibold">{d.vip_program ? "Yes" : "No"}</dd>
              </div>
            )}
            {d.kycRequired !== undefined && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">badge</span>
                  KYC Required
                </dt>
                <dd class="text-on-surface font-semibold">{d.kycRequired ? "Yes" : "No"}</dd>
              </div>
            )}
            {d.lastVerified && (
              <div class="flex justify-between">
                <dt class="text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-outline text-sm">verified</span>
                  Last Verified
                </dt>
                <dd class="text-on-surface font-semibold">{d.lastVerified}</dd>
              </div>
            )}
          </dl>
        </div>

        {/* Categories — SEO internal linking */}
        {d.categories && d.categories.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">label</span>
              Categories
            </h3>
            <div class="flex flex-wrap gap-2">
              {d.categories.map((cat: string) => {
                const catMap = {
                  "crypto-casino": "/crypto-casinos/",
                  "bitcoin-casino": "/crypto-casinos/",
                  "fast-withdrawal-casino": "/fast-withdrawal-casinos/",
                  "instant-withdrawal-casino": "/fast-withdrawal-casinos/",
                  "new-casino": "/new-casinos/",
                  "no-deposit-bonus": "/no-deposit-bonus/",
                  "online-casino": "/best-online-casinos/",
                } as any;
                const href = catMap[cat];
                const label = cat.replace(/-/g, " ").replace(/\b\w/g, (l: string) => l.toUpperCase());
                return href ? (
                  <a href={href} class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md hover:text-primary hover:bg-surface-container-highest transition-all">
                    {label}
                  </a>
                ) : (
                  <span class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md">
                    {label}
                  </span>
                );
              })}
            </div>
          </div>
        )}
      </aside>
    </div>

    {/* ───────────────── RELATED CASINOS ───────────────── */}
    {related.length > 0 && (
      <section class="mt-20">
        <RelatedContent
          title="Related Casinos"
          items={related.map((r) => ({ slug: r.data.slug, collection: "casinos", data: r.data }))}
          type="casino"
        />
      </section>
    )}
  </div>
</BaseLayout>
