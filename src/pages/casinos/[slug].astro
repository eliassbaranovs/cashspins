---
import { getCollection, render } from "astro:content";
import BonusTermsCard from "../../components/BonusTermsCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTAButton from "../../components/CTAButton.astro";
import FAQSection from "../../components/FAQSection.astro";
import LicenseBadge from "../../components/LicenseBadge.astro";
import ProsCons from "../../components/ProsCons.astro";
import RatingStars from "../../components/RatingStars.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRelatedByTags } from "../../lib/collections";
import { buildCanonical, generateFAQSchema, generateReviewSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const casinos = await getCollection("casinos");
  return casinos.map((casino) => ({
    params: { slug: casino.data.slug },
    props: { casino },
  }));
}

const { casino } = Astro.props;
const d: any = casino.data;
const { Content } = await render(casino);

const depositArr = d.deposit_methods ?? [];
const withdrawalArr = d.withdrawal_methods ?? [];
const providersArr = d.game_providers ?? [];
const currenciesArr = d.currencies ?? [];

// Related casinos
const allCasinos = await getCollection("casinos");
const related = getRelatedByTags(d.tags ?? [], allCasinos, d.slug, 3);

// Author — schema uses snake_case `author_slug`.
let authorEntry: any = undefined;
try {
  if (d.author_slug) {
    const authors = await getCollection("authors");
    authorEntry = authors.find((a) => a.data.slug === d.author_slug);
  }
} catch {}
const authorName = authorEntry?.data?.name ?? d.author_slug;

// Casino display name — H1 should be the brand, not the full article title.
const displayName = d.name ?? d.title;

// Formatted publish date for the hero meta row.
const publishedDate = d.published_at
  ? new Date(d.published_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
  : null;

// SEO schemas
const canonical = buildCanonical(`casinos/${d.slug}`);
const reviewSchema = generateReviewSchema({
  title: displayName,
  description: d.description ?? "",
  rating: d.rating,
  image: d.image,
  author_name: authorName,
  published_at: d.published_at,
  slug: d.slug,
});

const faqSchema = d.faqs?.length ? generateFAQSchema(d.faqs) : undefined;

// Combine schemas
const schemas: string[] = [reviewSchema];
if (faqSchema) schemas.push(faqSchema);
const combinedSchema = `[${schemas.join(",")}]`;
---

<BaseLayout
  title={d.title}
  seoTitle={d.seo_title}
  description={d.description}
  image={d.image}
  imageAlt={d.image_alt}
  canonical={canonical}
  schemaJsonLd={combinedSchema}
  ogType="article"
>
  <div class="max-w-screen-2xl mx-auto px-4 md:px-8 pt-8 pb-20">

    {/* ───────────────── HERO HEADER ───────────────── */}
    <div class="mb-6">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Casino Reviews", href: "/casinos/" },
          { label: displayName },
        ]}
      />
    </div>

    <header class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">

      {/* Left column — identity + meta */}
      <div class="lg:col-span-8 flex flex-col justify-center">
        <div class="flex flex-col sm:flex-row items-start gap-5 sm:gap-6">
          {/* Logo tile — matches the standardized pattern used across lists */}
          {d.logo ? (
            <img
              src={d.logo}
              alt={`${displayName} logo`}
              class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl bg-surface-container-lowest object-contain p-3 shrink-0"
              loading="eager"
              width="128"
              height="128"
            />
          ) : (
            <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-xl bg-surface-container-lowest flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-outline text-4xl">casino</span>
            </div>
          )}

          <div class="min-w-0 flex-1">
            {/* Eyebrow row — editorial badges grouped together */}
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {d.rating != null && d.rating >= 8 && (
                <span class="inline-flex items-center gap-1 bg-secondary/15 text-secondary text-[10px] font-black tracking-widest uppercase px-2 py-1 rounded-sm">
                  <span class="material-symbols-outlined" style="font-size:12px; font-variation-settings: 'FILL' 1;">verified</span>
                  Verified Expert Choice
                </span>
              )}
              {d.license && (
                <LicenseBadge license={d.license} licenseStatus={d.license_status} size="sm" />
              )}
            </div>

            {/* H1 — the casino brand, NOT the article title */}
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-headline font-extrabold tracking-tighter text-on-surface leading-tight mb-3">
              {displayName}
            </h1>

            {/* Single unified meta row — rating, author, date */}
            <div class="flex items-center gap-3 flex-wrap text-sm text-on-surface-variant">
              {d.rating != null && (
                <span class="inline-flex items-center gap-2">
                  <RatingStars rating={d.rating} />
                  <span class="font-bold text-on-surface">{d.rating.toFixed(1)}/10</span>
                </span>
              )}
              {authorName && (
                <>
                  <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                  <span class="inline-flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">person</span>
                    Reviewed by {authorName}
                  </span>
                </>
              )}
              {publishedDate && (
                <>
                  <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                  <time datetime={d.published_at} class="inline-flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">calendar_today</span>
                    {publishedDate}
                  </time>
                </>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Right column — Bonus CTA card */}
      <div class="lg:col-span-4">
        <div class="bg-surface-container-low rounded-xl p-8 relative overflow-hidden flex flex-col items-center text-center shadow-2xl group transition-all duration-500 hover:bg-surface-container">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-50 pointer-events-none"></div>

          <p class="text-on-surface-variant font-label font-bold tracking-widest uppercase text-xs mb-4">
            Exclusive Welcome Bonus
          </p>

          {d.bonus_value ? (
            <h2 class="text-primary text-3xl sm:text-4xl font-headline font-extrabold tracking-tighter mb-2">
              {d.bonus_value}
            </h2>
          ) : (
            <h2 class="text-on-surface text-2xl font-headline font-bold mb-2">
              Claim your welcome offer
            </h2>
          )}

          {d.bonus_wagering && d.bonus_wagering.length < 40 ? (
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Wagering: {d.bonus_wagering}. T&Cs apply.
            </p>
          ) : (
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              T&Cs apply.
            </p>
          )}

          <div class="w-full">
            <CTAButton
              href={`/go/${d.slug}/`}
              label="Claim Bonus Now"
              variant="primary"
              size="lg"
              sponsored={true}
              ariaLabel={`Claim bonus at ${displayName}`}
            />
          </div>

          <p class="mt-4 text-[10px] text-outline opacity-60">
            18+ | <a href="/responsible-gambling/" class="hover:text-primary transition-colors">Play Responsibly</a> | <a href="/affiliate-disclosure/" class="hover:text-primary transition-colors">Affiliate Disclosure</a> | New Customers Only
          </p>
        </div>
      </div>
    </header>

    {/* ───────────────── QUICK STATS GRID ───────────────── */}
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {d.payout_speed && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">speed</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Payout Speed</p>
          <p class="font-bold text-on-surface text-sm line-clamp-2">{d.payout_speed}</p>
        </div>
      )}

      {d.license && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-secondary/20">
          <span class="material-symbols-outlined text-secondary mb-3">gavel</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Licensing</p>
          <p class="font-bold text-on-surface text-sm line-clamp-2">{d.license}</p>
        </div>
      )}

      {d.game_count != null && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-tertiary/20">
          <span class="material-symbols-outlined text-tertiary mb-3">casino</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Total Games</p>
          <p class="font-bold text-on-surface">{d.game_count.toLocaleString()}+ Titles</p>
        </div>
      )}

      {d.min_deposit && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">savings</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Min. Deposit</p>
          <p class="font-bold text-on-surface">{d.min_deposit}</p>
        </div>
      )}

      {/* Fallbacks — shown only when the primary fields above are missing, so the strip stays four tiles wide */}
      {!d.payout_speed && d.established && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">history</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Established</p>
          <p class="font-bold text-on-surface">{d.established}</p>
        </div>
      )}

      {!d.min_deposit && d.owner && (
        <div class="bg-surface-container-lowest p-6 rounded-lg border-b-2 border-primary/20">
          <span class="material-symbols-outlined text-primary mb-3">apartment</span>
          <p class="text-xs text-outline font-bold tracking-wide uppercase mb-1">Operator</p>
          <p class="font-bold text-on-surface text-sm line-clamp-2">{d.owner}</p>
        </div>
      )}
    </section>

    {/* Cover Image */}
    {d.image && (
      <div class="mb-16 rounded-xl overflow-hidden">
        <img
          src={d.image}
          alt={d.image_alt ?? `${displayName} review`}
          width={1792}
          height={1024}
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    )}

    {/* ───────────────── TWO-COLUMN LAYOUT ───────────────── */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      {/* Main content */}
      <div class="lg:col-span-8 space-y-16">

        {/* Pros & Cons */}
        <ProsCons pros={d.pros} cons={d.cons} />

        {/* Screenshots — proof of legitimacy */}
        {d.screenshots && d.screenshots.length > 0 && (
          <section>
            <h2 class="font-headline font-bold text-2xl text-on-surface mb-2 flex items-center gap-3">
              <span class="material-symbols-outlined text-secondary">photo_library</span>
              Inside the Casino
            </h2>
            <p class="text-on-surface-variant text-sm mb-6">Real screenshots from our review — showing the live lobby, bonus pages, and license details.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {d.screenshots.map((s: any) => (
                <button type="button" class="screenshot-trigger rounded-xl overflow-hidden bg-surface-container-low border border-outline-variant/10 hover:border-primary/30 transition-all cursor-zoom-in text-left" data-src={s.url} data-alt={s.alt ?? `${d.casinoName} screenshot`}>
                  <div class="aspect-[4/3] bg-surface-container-lowest flex items-center justify-center p-2">
                    <img
                      src={s.url}
                      alt={s.alt ?? `${d.casinoName} screenshot`}
                      loading="lazy"
                      class="max-w-full max-h-full object-contain rounded-lg"
                    />
                  </div>
                  {s.alt && (
                    <p class="px-3 py-2 text-xs text-on-surface-variant">{s.alt}</p>
                  )}
                </button>
              ))}
            </div>
          </section>
        )}

        {/* Article body */}
        <article class="prose prose-invert max-w-none text-on-surface-variant leading-relaxed">
          <Content />
        </article>

        {/* Author Card — E-E-A-T signal */}
        {(d.author || authorEntry) && (
          <section class="bg-surface-container-low rounded-xl p-6 flex flex-col sm:flex-row gap-5 items-start">
            {authorEntry?.data?.avatar && (
              <img
                src={authorEntry.data.avatar}
                alt={authorEntry.data.name ?? d.author}
                class="w-16 h-16 rounded-full object-cover shrink-0"
                loading="lazy"
                width="64"
                height="64"
              />
            )}
            <div>
              <p class="text-xs font-label text-on-surface-variant uppercase tracking-wider mb-1">Reviewed by</p>
              <p class="font-headline font-bold text-on-surface text-lg">
                {authorEntry ? (
                  <a href={`/team/${authorEntry.data.slug}/`} class="hover:text-primary transition-colors">{authorEntry.data.name}</a>
                ) : d.author}
              </p>
              {authorEntry?.data?.role && (
                <p class="text-secondary text-xs font-bold mt-0.5">{authorEntry.data.role}</p>
              )}
              {authorEntry?.data?.bio && (
                <p class="text-on-surface-variant text-sm mt-2 line-clamp-2">{authorEntry.data.bio}</p>
              )}
              {authorEntry?.data?.expertise && authorEntry.data.expertise.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {authorEntry.data.expertise.map((tag: string) => (
                    <span class="bg-surface-container-highest text-on-surface-variant text-[10px] px-2 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </section>
        )}

        {/* Tags — internal linking */}
        {d.tags && d.tags.length > 0 && (
          <section>
            <div class="flex flex-wrap gap-2">
              {d.tags.map((tag: string) => (
                <span class="bg-surface-container-high text-on-surface-variant text-xs font-label px-3 py-1.5 rounded-full flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs">sell</span>
                  {tag}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* FAQ */}
        {d.faqs && d.faqs.length > 0 && (
          <FAQSection faqs={d.faqs} />
        )}

        {/* Responsible gambling + affiliate disclosure — YMYL trust block */}
        <section class="bg-surface-container-low rounded-xl p-6 border-l-4 border-error/40">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-error shrink-0 mt-0.5">info</span>
            <div class="text-sm text-on-surface-variant leading-relaxed">
              <p class="mb-2">
                <strong class="text-on-surface">18+ only.</strong> Gambling involves financial risk and can become addictive. If you or someone you know needs help, see our <a href="/responsible-gambling/" class="text-primary hover:underline">responsible gambling resources</a> or contact <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">GambleAware</a>.
              </p>
              <p>
                CashSpins earns affiliate commission when readers sign up through links on this page. Ratings and editorial conclusions are not influenced by these payments &mdash; full details in our <a href="/affiliate-disclosure/" class="text-primary hover:underline">affiliate disclosure</a>.
              </p>
            </div>
          </div>
        </section>
      </div>

      {/* Sidebar */}
      <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-24">

        {/* Bonus Terms at a Glance */}
        <BonusTermsCard
          wagering={d.bonus_wagering}
          minDeposit={d.bonus_min_deposit}
          maxBet={d.bonus_max_bet}
          timeLimit={d.bonus_time_limit}
          bonusCode={d.bonus_code}
        />

        {/* All Bonuses */}
        {d.bonuses && d.bonuses.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-5 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">redeem</span>
              All Current Offers
            </h3>
            <div class="space-y-3">
              {d.bonuses.map((bonus: any) => {
                const nf = (v: any) => v != null && String(v) !== "NOT_FOUND" && String(v) !== "N/A" && String(v) !== "0";
                const hasData = nf(bonus.percentage) || nf(bonus.amount) || (bonus.free_spins != null && Number(bonus.free_spins) > 0) || nf(bonus.wagering);
                if (!hasData) return null;
                return (
                <div class="bg-surface-container rounded-xl p-4 border border-outline-variant/10 hover:border-primary/25 transition-colors">
                  <div class="flex items-start justify-between gap-2 mb-2">
                    <p class="text-on-surface font-headline font-bold text-sm leading-snug">{bonus.name}</p>
                    {bonus.type && (
                      <span class="shrink-0 px-2 py-0.5 bg-secondary-container/20 text-secondary text-[9px] font-bold uppercase tracking-widest rounded-sm">
                        {bonus.type}
                      </span>
                    )}
                  </div>
                  <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs mb-3">
                    {bonus.percentage && bonus.percentage !== "N/A" && bonus.percentage !== "NOT_FOUND" && (
                      <span class="text-primary font-bold">{bonus.percentage}</span>
                    )}
                    {bonus.amount && bonus.amount !== "NOT_FOUND" && (
                      <span class="text-secondary font-semibold">{bonus.amount}</span>
                    )}
                    {bonus.free_spins != null && bonus.free_spins !== "NOT_FOUND" && Number(bonus.free_spins) > 0 && (
                      <span class="inline-flex items-center gap-0.5 text-on-surface-variant">
                        <span class="material-symbols-outlined text-[11px]">motion_play</span>
                        {bonus.free_spins} spins
                      </span>
                    )}
                    {(() => {
                      const wr = bonus.wagering ?? d.wagering;
                      return wr && wr !== "NOT_FOUND" && !wr.startsWith("The ") && wr.length < 40 ? (
                        <span class="text-outline">WR: {wr}</span>
                      ) : null;
                    })()}
                  </div>
                  <a
                    href={`/go/${d.slug}/`}
                    data-sponsored="true"
                    rel="nofollow noopener sponsored"
                    class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-primary/90 hover:bg-primary text-on-primary text-xs font-bold rounded-lg transition-colors"
                  >
                    Claim
                  </a>
                </div>
              );})}
            </div>
          </div>
        )}

        {/* Accepted Cryptos */}
        {d.acceptedCryptos && d.acceptedCryptos.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">currency_bitcoin</span>
              Accepted Crypto
            </h3>
            <div class="flex flex-wrap gap-2">
              {d.acceptedCryptos.map((crypto: string) => (
                <span class="px-3 py-1 bg-surface-container-lowest rounded-full text-xs font-label text-on-surface-variant">
                  {crypto}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* Payment Methods */}
        {(depositArr.length > 0 || withdrawalArr.length > 0) && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">account_balance_wallet</span>
              Payment Methods
            </h3>
            {depositArr.length > 0 && (
              <div class="mb-4">
                <p class="text-[10px] text-outline font-bold uppercase tracking-widest mb-2">Deposit</p>
                <div class="flex flex-wrap gap-1.5">
                  {depositArr.map((m: string) => (
                    <span class="px-2.5 py-1 bg-surface-container text-on-surface-variant text-xs rounded-lg border border-outline-variant/15 hover:border-primary/30 hover:text-on-surface transition-colors">
                      {m}
                    </span>
                  ))}
                </div>
              </div>
            )}
            {withdrawalArr.length > 0 && (
              <div>
                <p class="text-[10px] text-outline font-bold uppercase tracking-widest mb-2">Withdrawal</p>
                <div class="flex flex-wrap gap-1.5">
                  {withdrawalArr.map((m: string) => (
                    <span class="px-2.5 py-1 bg-surface-container text-on-surface-variant text-xs rounded-lg border border-outline-variant/15 hover:border-primary/30 hover:text-on-surface transition-colors">
                      {m}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* Currencies */}
        {currenciesArr.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">payments</span>
              Currencies
            </h3>
            <div class="flex flex-wrap gap-2">
              {currenciesArr.map((c: string) => (
                <span class="px-3 py-1 bg-surface-container-lowest rounded-full text-xs font-label text-on-surface-variant">{c}</span>
              ))}
            </div>
          </div>
        )}

        {/* Game Providers */}
        {providersArr.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">sports_esports</span>
              Game Providers
              <span class="ml-auto text-xs text-outline font-normal font-label normal-case tracking-normal">{providersArr.length} total</span>
            </h3>
            <div class="flex flex-wrap gap-1.5">
              {providersArr.slice(0, 12).map((p: string) => (
                <span class="px-2 py-0.5 bg-surface-container text-on-surface-variant text-xs rounded-lg border border-outline-variant/10">
                  {p}
                </span>
              ))}
              {providersArr.length > 12 && (
                <span class="relative group inline-block">
                  <span class="cursor-help px-2.5 py-0.5 bg-secondary/10 text-secondary text-xs font-semibold rounded-lg border border-secondary/20 hover:border-secondary/50 transition-colors inline-block">
                    +{providersArr.length - 12} more
                  </span>
                  <span class="pointer-events-none absolute bottom-full right-0 mb-2 w-72 bg-surface-container-highest text-on-surface-variant text-[11px] rounded-xl p-3 shadow-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-50 leading-relaxed">
                    {providersArr.slice(12).join(" · ")}
                  </span>
                </span>
              )}
            </div>
          </div>
        )}

        {/* Key Info */}
        <div class="bg-surface-container-low rounded-xl p-6">
          <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-secondary">info</span>
            Key Info
          </h3>
          <dl class="space-y-2.5 text-sm">
            {d.established && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">history</span>
                  Established
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.established}</dd>
              </div>
            )}
            {d.company && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">apartment</span>
                  Operator
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.company}</dd>
              </div>
            )}
            {d.casino_type && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">category</span>
                  Type
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.casino_type}</dd>
              </div>
            )}
            {d.wagering && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">calculate</span>
                  Wagering
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.wagering}</dd>
              </div>
            )}
            {d.vip_program !== undefined && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">workspace_premium</span>
                  VIP Program
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.vip_program ? "Yes" : "No"}</dd>
              </div>
            )}
            {d.kycRequired !== undefined && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">badge</span>
                  KYC Required
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.kycRequired ? "Yes" : "No"}</dd>
              </div>
            )}
            {d.lastVerified && (
              <div class="grid grid-cols-[auto_1fr] items-start gap-x-3">
                <dt class="text-on-surface-variant flex items-center gap-1 whitespace-nowrap pt-0.5">
                  <span class="material-symbols-outlined text-outline text-sm">verified</span>
                  Last Verified
                </dt>
                <dd class="text-on-surface font-semibold text-right">{d.lastVerified}</dd>
              </div>
            )}
          </dl>
        </div>

        {/* Categories — SEO internal linking */}
        {d.categories && d.categories.length > 0 && (
          <div class="bg-surface-container-low rounded-xl p-6">
            <h3 class="font-headline font-bold text-lg text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary">label</span>
              Categories
            </h3>
            <div class="flex flex-wrap gap-2">
              {d.categories.map((cat: string) => {
                const catMap = {
                  "crypto-casino": "/crypto-casinos/",
                  "bitcoin-casino": "/crypto-casinos/",
                  "fast-withdrawal-casino": "/fast-withdrawal-casinos/",
                  "instant-withdrawal-casino": "/fast-withdrawal-casinos/",
                  "new-casino": "/new-casinos/",
                  "no-deposit-bonus": "/no-deposit-bonus/",
                  "online-casino": "/best-online-casinos/",
                  "licensed-casino": "/best-online-casinos/",
                  "vip-program-casino": "/best-online-casinos/",
                  "mobile-casino": "/mobile-casinos/",
                } as any;
                const href = catMap[cat];
                const label = cat.replace(/-/g, " ").replace(/\b\w/g, (l: string) => l.toUpperCase());
                return href ? (
                  <a href={href} class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md hover:text-primary hover:bg-surface-container-highest transition-all">
                    {label}
                  </a>
                ) : (
                  <span class="bg-surface-container-lowest text-on-surface-variant text-xs px-2.5 py-1 rounded-md">
                    {label}
                  </span>
                );
              })}
            </div>
          </div>
        )}
      </aside>
    </div>

    {/* ───────────────── RELATED CASINOS ───────────────── */}
    {related.length > 0 && (
      <section class="mt-20">
        <RelatedContent
          title="Related Casinos"
          items={related.map((r) => ({ slug: r.data.slug, collection: "casinos", data: r.data }))}
          type="casino"
        />
      </section>
    )}
  </div>

  {/* Screenshot lightbox */}
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-surface/90 backdrop-blur-sm cursor-zoom-out" role="dialog" aria-modal="true" aria-label="Screenshot preview">
    <button type="button" id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface-variant hover:text-on-surface transition-colors" aria-label="Close">
      <span class="material-symbols-outlined">close</span>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain rounded-xl shadow-2xl" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    document.querySelectorAll('.screenshot-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.src;
        const alt = (btn as HTMLElement).dataset.alt;
        if (lightboxImg && src) {
          lightboxImg.src = src;
          lightboxImg.alt = alt || '';
        }
        lightbox?.classList.remove('hidden');
        lightbox?.classList.add('flex');
      });
    });

    function closeLightbox() {
      lightbox?.classList.add('hidden');
      lightbox?.classList.remove('flex');
    }

    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });
  </script>
</BaseLayout>
