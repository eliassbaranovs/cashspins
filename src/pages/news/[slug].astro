---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedContent from "../../components/RelatedContent.astro";
import { buildCanonical, generateArticleSchema } from "../../lib/seo";
import { getRelatedByTags } from "../../lib/collections";

export async function getStaticPaths() {
  let items: Awaited<ReturnType<typeof getCollection>> = [];
  try {
    items = await getCollection("news");
  } catch {
    return [];
  }
  return items
    .map((item: any) => ({ params: { slug: item.data.slug }, props: { item } }));
}

const { item } = Astro.props;
const d = item.data;
const { Content } = await render(item);

// Related articles
let allNews: any[] = [];
try {
  allNews = await getCollection("news");
} catch {
  allNews = [];
}
const related = getRelatedByTags(d.tags ?? [], allNews, d.slug, 3);

// Resolve author
let authorEntry: any = undefined;
try {
  if (d.author_slug) {
    const authors = await getCollection("authors");
    authorEntry = authors.find((a: any) => a.data.slug === d.author_slug);
  }
} catch {}
const authorName = authorEntry?.data?.name ?? d.author_slug;

// Schema
const articleSchema = generateArticleSchema({
  title: d.title,
  description: d.description,
  image: d.image,
  author_name: authorName,
  published_at: d.published_at,
});

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "News", href: "/news/" },
  { label: d.title },
];

const formattedDate = d.published_at
  ? new Date(d.published_at).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<BaseLayout
  title={d.title}
  seoTitle={d.seo_title}
  description={d.description}
  image={d.image}
  imageAlt={d.image_alt}
  canonical={buildCanonical(`news/${d.slug}`)}
  schemaJsonLd={articleSchema}
  ogType="article"
>
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8 pt-8 pb-20">
    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <article class="max-w-4xl mx-auto">
      <!-- Article Header -->
      <header class="mb-10">
        {/* Category badge */}
        {d.category && (
          <span class="inline-block bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-sm mb-4">
            {d.category}
          </span>
        )}

        {/* Meta line */}
        <div class="flex items-center flex-wrap gap-3 text-sm font-label text-on-surface-variant mb-4">
          {formattedDate && (
            <time datetime={d.published_at} class="flex items-center gap-1.5">
              <span class="material-symbols-outlined text-sm">calendar_today</span>
              {formattedDate}
            </time>
          )}
          {authorName && (
            <>
              <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
              <span class="flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">person</span>
                {authorName}
              </span>
            </>
          )}
        </div>

        <h1 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight text-on-surface leading-tight mb-6">
          {d.title}
        </h1>

        {d.excerpt && (
          <p class="text-on-surface-variant text-lg leading-relaxed">{d.excerpt}</p>
        )}
      </header>

      {/* Featured Image */}
      {d.image && (
        <div class="rounded-xl overflow-hidden mb-10">
          <img
            src={d.image}
            alt={d.image_alt || d.title}
            width={1792}
            height={1024}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      )}

      {/* Article Body */}
      <div class="prose prose-invert max-w-none mb-16
        [&_h2]:font-headline [&_h2]:font-bold [&_h2]:text-2xl [&_h2]:text-on-surface [&_h2]:border-b [&_h2]:border-outline-variant/20 [&_h2]:pb-3 [&_h2]:mb-6 [&_h2]:mt-10
        [&_h3]:font-headline [&_h3]:font-bold [&_h3]:text-xl [&_h3]:text-on-surface
        [&_a]:text-primary [&_a]:hover:underline
        [&_strong]:text-on-surface
        [&_p]:text-on-surface-variant [&_p]:leading-relaxed
        [&_li]:text-on-surface-variant
        [&_blockquote]:border-l-4 [&_blockquote]:border-primary/40 [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-on-surface-variant
      ">
        <Content />
      </div>

      {/* Tags */}
      {d.tags?.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12 pb-8 border-b border-outline-variant/20">
          {d.tags.map((tag: string) => (
            <span class="bg-surface-container-high text-on-surface-variant text-xs font-label px-3 py-1.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}

      {/* Source attribution */}
      {d.source_url && (
        <div class="bg-surface-container-low rounded-xl p-6 mb-12 flex items-center gap-3">
          <span class="material-symbols-outlined text-on-surface-variant">link</span>
          <p class="text-on-surface-variant text-sm">
            Source: <a href={d.source_url} rel="noopener noreferrer nofollow" target="_blank" class="text-primary hover:underline">
              {d.source_url}
            </a>
          </p>
        </div>
      )}

      {/* Related Content */}
      {related.length > 0 && (
        <RelatedContent
          title="Related News"
          items={related.map((r: any) => ({
            slug: r.data.slug,
            collection: "news",
            data: r.data,
          }))}
        />
      )}
    </article>
  </div>
</BaseLayout>
