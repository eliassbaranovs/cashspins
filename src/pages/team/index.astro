---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { buildCanonical } from "../../lib/seo";

const authors = await getCollection("authors");
const allCasinos = await getCollection("casinos");
const allBonuses = await getCollection("bonuses");

const articleCount = new Map<string, number>();
for (const entry of [...allCasinos, ...allBonuses]) {
  const slug = entry.data.author_slug;
  if (slug) articleCount.set(slug, (articleCount.get(slug) ?? 0) + 1);
}

const siteBase = "https://cashspins.online";

// CollectionPage + embedded ItemList of Person objects. Each Person has an @id
// that lines up with the hash-id the /team/[slug] page emits, so Google can
// fold the list entry into the full author profile.
const teamSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${siteBase}/team/#collection`,
  name: "The CashSpins Editorial Team",
  url: `${siteBase}/team/`,
  description: "Every review on CashSpins is written and fact-checked by a specialist with real hands-on iGaming experience.",
  isPartOf: { "@id": `${siteBase}/#website` },
  publisher: { "@id": `${siteBase}/#organization` },
  mainEntity: {
    "@type": "ItemList",
    name: "CashSpins Editors and Reviewers",
    numberOfItems: authors.length,
    itemListElement: authors.map((a: any, i: number) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Person",
        "@id": `${siteBase}/team/${a.data.slug}/#person`,
        name: a.data.name,
        url: `${siteBase}/team/${a.data.slug}/`,
        jobTitle: a.data.role ?? "Casino Analyst",
        ...(a.data.avatar && { image: `${siteBase}${a.data.avatar}` }),
        ...(a.data.expertise?.length && { knowsAbout: a.data.expertise }),
        worksFor: { "@id": `${siteBase}/#organization` },
      },
    })),
  },
});
---

<BaseLayout
  title="Our Expert Team | CashSpins"
  description="Meet the CashSpins editorial team — certified iGaming specialists who write and verify every casino review and bonus analysis."
  canonical={buildCanonical("team")}
  schemaJsonLd={teamSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-8 py-12">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Our Team" },
    ]} />

    <header class="text-center mt-8 mb-12">
      <h1 class="font-headline font-extrabold text-4xl md:text-5xl text-on-surface mb-4">
        The Editorial Team
      </h1>
      <p class="text-on-surface-variant max-w-xl mx-auto leading-relaxed">
        Every review on CashSpins is written and fact-checked by a specialist with real hands-on experience.
        Meet the analysts behind the ratings.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {authors.map((author) => {
        const d = author.data;
        const count = articleCount.get(d.slug) ?? 0;
        const bioSnippet = d.bio.length > 120 ? d.bio.slice(0, 117) + "..." : d.bio;

        return (
          <a
            href={`/team/${d.slug}/`}
            class="group bg-surface-container-low rounded-xl p-6 ghost-border hover:border-primary/40 transition-all flex flex-col items-center text-center"
          >
            <img
              src={d.avatar}
              alt={`${d.name} — ${d.role ?? "Casino Analyst"}`}
              width="96"
              height="96"
              loading="lazy"
              decoding="async"
              class="w-24 h-24 rounded-full object-cover border-3 border-primary mb-4"
              onerror="this.src='/images/authors/placeholder.png'"
            />

            <h2 class="font-headline font-bold text-lg text-on-surface group-hover:text-primary transition-colors">
              {d.name}
            </h2>

            {d.role && (
              <span class="inline-block mt-1 text-xs font-label text-primary bg-primary/10 px-3 py-0.5 rounded-full">
                {d.role}
              </span>
            )}

            <p class="text-on-surface-variant text-sm mt-3 leading-relaxed">
              {bioSnippet}
            </p>

            {d.expertise && d.expertise.length > 0 && (
              <div class="flex flex-wrap justify-center gap-1.5 mt-3">
                {d.expertise.slice(0, 3).map((tag: string) => (
                  <span class="text-xs text-on-surface-variant bg-surface-container-lowest border border-outline-variant/20 px-2 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <span class="text-xs text-on-surface-variant mt-3">
              {count} article{count !== 1 ? "s" : ""} published
            </span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
