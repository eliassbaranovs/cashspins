---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.data.slug },
    props: { author },
  }));
}

const { author } = Astro.props;
const d = author.data;

const [casinos, bonuses, guides, news, comparisons] = await Promise.all([
  getCollection("casinos"),
  getCollection("bonuses"),
  getCollection("guides"),
  getCollection("news"),
  getCollection("comparisons"),
]);

const byAuthor = (p: any) => p.data.author_slug === d.slug;

const authorCasinos = casinos.filter(byAuthor)
  .sort((a, b) => (b.data.rating ?? 0) - (a.data.rating ?? 0));
const authorBonuses = bonuses.filter(byAuthor);
const authorGuides = guides.filter(byAuthor);
const authorNews = news.filter(byAuthor);
const authorComparisons = comparisons.filter(byAuthor);

const totalArticles = authorCasinos.length + authorBonuses.length + authorGuides.length + authorNews.length + authorComparisons.length;

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": author.data.name,
  "jobTitle": author.data.role ?? "Casino Analyst",
  "description": author.data.bio,
  "knowsAbout": author.data.expertise ?? [],
  ...(author.data.credentials?.length ? {
    "hasCredential": author.data.credentials.map((c: string) => ({
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "Certification",
      "name": c,
    })),
  } : {}),
  "sameAs": [],
  "url": `https://cashspins.online/team/${author.data.slug}/`,
  ...(author.data.avatar ? { "image": `https://cashspins.online${author.data.avatar}` } : {}),
});
---

<BaseLayout
  title={`${d.name} — ${d.role ?? "Casino Analyst"} | CashSpins`}
  description={d.bio.length > 160 ? d.bio.slice(0, 157) + "..." : d.bio}
  ogType="profile"
  schemaJsonLd={personSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-8 py-12">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Our Team", href: "/team/" },
      { label: d.name },
    ]} />

    {/* Hero / Profile Header */}
    <div class="flex flex-col md:flex-row gap-8 items-start mt-8 pb-8 border-b border-outline-variant/20">
      <img
        src={d.avatar}
        alt={`${d.name} — ${d.role ?? "Casino Analyst"}`}
        width="128"
        height="128"
        loading="eager"
        decoding="async"
        class="w-32 h-32 rounded-full object-cover border-3 border-primary shrink-0"
        onerror="this.src='/images/authors/placeholder.png'"
      />

      <div class="flex flex-col gap-3">
        <h1 class="font-headline font-extrabold text-3xl md:text-4xl text-on-surface">
          {d.name}
        </h1>

        {d.role && (
          <span class="inline-block text-sm font-label text-primary font-semibold">
            {d.role}
          </span>
        )}

        {d.credentials && d.credentials.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {d.credentials.map((c: string) => (
              <span class="text-xs text-primary bg-primary/10 border border-primary/20 px-3 py-1 rounded-full">
                {c}
              </span>
            ))}
          </div>
        )}

        <div class="text-on-surface-variant leading-relaxed max-w-2xl space-y-3">
          {d.bio.split('\n').filter((p: string) => p.trim()).map((paragraph: string) => (
            <p>{paragraph}</p>
          ))}
        </div>

        {d.expertise && d.expertise.length > 0 && (
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs text-on-surface-variant font-label uppercase tracking-wider">Specialisms:</span>
            {d.expertise.map((e: string) => (
              <span class="text-xs text-on-surface-variant bg-surface-container-lowest border border-outline-variant/20 px-2 py-0.5 rounded">
                {e}
              </span>
            ))}
          </div>
        )}

      </div>
    </div>

    {/* Article count */}
    <p class="text-on-surface-variant text-sm mt-6 mb-8">
      <span class="material-symbols-outlined text-sm align-middle mr-1">article</span>
      {totalArticles} article{totalArticles !== 1 ? "s" : ""} published
    </p>

    {/* Casino Reviews */}
    {authorCasinos.length > 0 && (
      <section class="mb-10">
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4 pb-3 border-b border-outline-variant/20">
          Casino Reviews
        </h2>
        <div class="space-y-3">
          {authorCasinos.map((entry) => (
            <a
              href={`/casinos/${entry.data.slug}/`}
              class="flex items-baseline gap-4 flex-wrap bg-surface-container-low rounded-lg px-5 py-4 ghost-border hover:border-primary/30 transition-all"
            >
              <span class="text-on-surface font-medium flex-1 min-w-[180px]">
                {entry.data.name ?? entry.data.title}
              </span>
              {entry.data.rating && (
                <span class="text-xs text-primary font-semibold">
                  Rating: {entry.data.rating}/10
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Bonus Guides */}
    {authorBonuses.length > 0 && (
      <section class="mb-10">
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4 pb-3 border-b border-outline-variant/20">
          Bonus Guides
        </h2>
        <div class="space-y-3">
          {authorBonuses.map((entry) => (
            <a
              href={`/bonus/${entry.data.slug}/`}
              class="flex items-baseline gap-4 flex-wrap bg-surface-container-low rounded-lg px-5 py-4 ghost-border hover:border-primary/30 transition-all"
            >
              <span class="text-on-surface font-medium flex-1 min-w-[180px]">
                {entry.data.bonus_value ?? entry.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Guides */}
    {authorGuides.length > 0 && (
      <section class="mb-10">
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4 pb-3 border-b border-outline-variant/20">
          Guides
        </h2>
        <div class="space-y-3">
          {authorGuides.map((entry) => (
            <a
              href={`/guides/${entry.data.slug}/`}
              class="flex items-baseline gap-4 flex-wrap bg-surface-container-low rounded-lg px-5 py-4 ghost-border hover:border-primary/30 transition-all"
            >
              <span class="text-on-surface font-medium flex-1 min-w-[180px]">
                {entry.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* News */}
    {authorNews.length > 0 && (
      <section class="mb-10">
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4 pb-3 border-b border-outline-variant/20">
          News Articles
        </h2>
        <div class="space-y-3">
          {authorNews.map((entry) => (
            <a
              href={`/news/${entry.data.slug}/`}
              class="flex items-baseline gap-4 flex-wrap bg-surface-container-low rounded-lg px-5 py-4 ghost-border hover:border-primary/30 transition-all"
            >
              <span class="text-on-surface font-medium flex-1 min-w-[180px]">
                {entry.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Comparisons */}
    {authorComparisons.length > 0 && (
      <section class="mb-10">
        <h2 class="font-headline font-bold text-xl text-on-surface mb-4 pb-3 border-b border-outline-variant/20">
          Casino Comparisons
        </h2>
        <div class="space-y-3">
          {authorComparisons.map((entry) => (
            <a
              href={`/compare/${entry.data.slug}/`}
              class="flex items-baseline gap-4 flex-wrap bg-surface-container-low rounded-lg px-5 py-4 ghost-border hover:border-primary/30 transition-all"
            >
              <span class="text-on-surface font-medium flex-1 min-w-[180px]">
                {entry.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    {totalArticles === 0 && (
      <p class="text-on-surface-variant text-center py-12">
        No published articles yet.
      </p>
    )}
  </div>
</BaseLayout>
