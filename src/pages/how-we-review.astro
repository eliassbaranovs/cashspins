---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import FAQSection from "../components/FAQSection.astro";
import { generateFAQSchema } from "../lib/seo";
import { getCollection } from "astro:content";

const authors = await getCollection("authors");

const faqs = [
  {
    question: "How often are reviews updated?",
    answer: "We update reviews whenever a casino changes its terms, adds payment methods, or receives significant player complaints. Most reviews are refreshed at least quarterly. Every review displays the date it was last verified.",
  },
  {
    question: "Do affiliate partnerships influence your ratings?",
    answer: "Never. Our editorial and commercial operations are completely separate. Reviewers do not know the commission structure of any casino. We earn commissions when you visit a casino through our links, but this never affects our scores.",
  },
  {
    question: "Can a casino pay to improve its rating?",
    answer: "No. Ratings are based solely on our testing methodology. No payment, partnership, or sponsorship can influence a casino's score. If a highly profitable partner underperforms, it gets rated accordingly.",
  },
  {
    question: "What happens if a casino's standards drop?",
    answer: "We demote or remove it. If a casino receives serious player complaints, changes its terms unfairly, or loses its license, we update the review immediately — regardless of how much revenue that casino generates for us.",
  },
  {
    question: "How much money do you deposit when testing a casino?",
    answer: "We deposit a minimum of $50 equivalent in cryptocurrency for every review. This is real money from our own funds — not play money or accounts provided by the casino. We need to test the full deposit-to-withdrawal cycle with genuine transactions.",
  },
  {
    question: "Why are Payment Speed and Trust weighted highest?",
    answer: "Because they directly affect your money and safety. A casino with great games but slow payouts or a questionable license is a risk. We weight these factors at 25% each because in the crypto casino space, getting paid reliably and playing on a secure platform matter most.",
  },
];

const steps = [
  {
    icon: "person_add",
    title: "Registration & First Impressions",
    time: "15-30 minutes",
    description: "Every review begins with a fresh account registration. We evaluate the sign-up process, KYC requirements, account verification flow, interface quality on desktop and mobile, and overall first impressions. If a casino's onboarding is confusing or excessive, that's noted immediately.",
    checks: ["Sign-up steps and KYC timing", "Interface quality and load speed", "Language and localisation", "Mobile responsiveness"],
  },
  {
    icon: "account_balance_wallet",
    title: "Crypto Deposit Testing",
    time: "Real deposit, minimum $50 equivalent",
    description: "The reviewer makes a real cryptocurrency deposit to test payment infrastructure. We check which coins are supported, how quickly wallet addresses are generated, confirmation times, and whether the casino charges any deposit fees beyond network gas. Every deposit is a genuine transaction with real funds — never simulated.",
    checks: ["Supported cryptocurrencies (BTC, ETH, USDT, LTC minimum)", "Deposit confirmation speed", "Minimum deposit amount", "Casino-side fees"],
  },
  {
    icon: "redeem",
    title: "Bonus Evaluation",
    time: "Full T&C analysis",
    description: "We claim the welcome bonus and read every word of the terms. We calculate the effective bonus value — what the bonus is actually worth after wagering requirements, not the headline number. A $500 bonus with 60x wagering and $5 max bet is worth far less than a $200 bonus with 25x wagering.",
    checks: ["Wagering requirements and game weightings", "Max bet rules and time limits", "Max cashout caps on bonus winnings", "Effective value calculation"],
  },
  {
    icon: "casino",
    title: "Game Testing",
    time: "Minimum 2 hours gameplay",
    description: "We play across multiple game categories: 10+ slot titles from different providers, 3+ live tables evaluating stream quality and dealer professionalism, RNG table games, and crypto-native provably fair games. We also verify the claimed game count against actual available titles — many casinos inflate their numbers.",
    checks: ["Slots, live casino, table games, provably fair", "Provider quality (Evolution, Pragmatic, NetEnt)", "Game count verification vs. claims", "Mobile game performance"],
  },
  {
    icon: "payments",
    title: "Withdrawal Testing",
    time: "Measured to the minute",
    description: "We initiate a real withdrawal and measure every step: time from request to funds in wallet, any additional KYC triggered, minimum withdrawal amounts, daily/weekly limits, and fees. This is the most important step — it proves the casino actually pays out. Any casino that fails the withdrawal test does not receive a positive review.",
    checks: ["Withdrawal speed (timed precisely)", "KYC requirements at cashout", "Withdrawal limits and fees", "Payout reliability"],
  },
  {
    icon: "support_agent",
    title: "Customer Support Evaluation",
    time: "All available channels tested",
    description: "We contact support through every available channel with real questions — not generic greetings, but specific inquiries about bonus terms or withdrawal limits that require actual knowledge. If we can't reach a human within 3 minutes on live chat, the score drops. No one likes talking to a scripted FAQ bot.",
    checks: ["Live chat response time and quality", "Email response time (measured in hours)", "Agent knowledge and helpfulness", "24/7 availability and languages"],
  },
  {
    icon: "shield",
    title: "Security & Licensing Verification",
    time: "Independent verification",
    description: "We verify the casino's license by checking the licensing authority's public registry directly — not just looking at the badge on the website. We confirm SSL encryption, test responsible gambling tools (deposit limits, self-exclusion), review the privacy policy, and independently verify provably fair mechanisms for crypto-native games.",
    checks: ["License registry confirmation (MGA, UKGC, Curacao)", "SSL and site-wide encryption", "Responsible gambling tools (functional, not decorative)", "Provably fair hash verification"],
  },
  {
    icon: "scoreboard",
    title: "Scoring & Final Rating",
    time: "Weighted across 5 criteria",
    description: "Each casino is scored on five criteria using a weighted system. Payment Speed and Trust & Security carry the highest weight because they directly affect your money and safety. The final rating is a weighted average rounded to one decimal place.",
    checks: ["Bonus Value (20%)", "Game Selection (20%)", "Payment Speed (25%)", "Trust & Security (25%)", "User Experience (10%)"],
  },
];

const ratingTiers = [
  { range: "9.0 – 10.0", label: "Excellent", color: "green", icon: "verified", desc: "Top-tier casino, recommended without reservation." },
  { range: "8.0 – 8.9", label: "Very Good", color: "emerald", icon: "thumb_up", desc: "Strong casino with minor weaknesses." },
  { range: "7.0 – 7.9", label: "Good", color: "yellow", icon: "check_circle", desc: "Solid option with some notable drawbacks." },
  { range: "6.0 – 6.9", label: "Average", color: "orange", icon: "info", desc: "Acceptable but not recommended over better alternatives." },
  { range: "Below 6.0", label: "Below Average", color: "red", icon: "warning", desc: "Significant issues — proceed with caution or avoid." },
];
---

<BaseLayout
  title="How We Review Online Casinos — Our 8-Step Methodology | CashSpins"
  description="Learn about CashSpins' 8-step review process. We deposit real crypto, test withdrawals, audit bonus terms, verify licenses, and rate casinos on 5 weighted criteria."
>
  <div class="max-w-4xl mx-auto px-4 md:px-8 pt-8 pb-20">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "How We Review" },
      ]}
    />

    <!-- Hero -->
    <header class="mt-8 mb-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="h-px w-12 bg-secondary/40"></span>
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-secondary">Our Methodology</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-headline font-extrabold tracking-tighter mb-6 leading-none text-on-surface">
        How We Review Online Casinos
      </h1>
      <p class="max-w-2xl text-lg text-on-surface-variant leading-relaxed">
        Every casino on CashSpins is tested with real money by a named reviewer who documents the entire experience. Here is exactly how we evaluate every casino — step by step.
      </p>
    </header>

    <!-- 8-Step Process -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-10">Our 8-Step Review Process</h2>
      <div class="space-y-6">
        {steps.map((step, i) => (
          <div class="bg-surface-container-low rounded-xl p-8">
            <div class="flex items-start gap-4 mb-4">
              <span class="text-4xl font-headline font-extrabold text-primary/30 leading-none shrink-0">{String(i + 1).padStart(2, "0")}</span>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                  <span class="material-symbols-outlined text-2xl text-primary">{step.icon}</span>
                  <h3 class="font-headline font-bold text-xl text-on-surface">{step.title}</h3>
                </div>
                <span class="text-xs font-semibold text-secondary">{step.time}</span>
              </div>
            </div>
            <p class="text-on-surface-variant leading-relaxed mb-4">{step.description}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {step.checks.map((check) => (
                <div class="flex items-center gap-2 text-sm text-on-surface-variant">
                  <span class="material-symbols-outlined text-primary shrink-0" style="font-size: 16px;">check</span>
                  <span>{check}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Scoring Criteria Table -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-6">Scoring Criteria</h2>
      <p class="text-on-surface-variant leading-relaxed mb-8">
        Each casino is scored across five criteria on a 0-10 scale. Payment Speed and Trust & Security are weighted highest because in the crypto casino space, these factors most directly affect your money and safety.
      </p>
      <div class="bg-surface-container-low rounded-xl overflow-hidden">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-outline-variant/20">
              <th class="px-6 py-4 font-headline font-bold text-on-surface text-sm">Criteria</th>
              <th class="px-6 py-4 font-headline font-bold text-on-surface text-sm text-center">Weight</th>
              <th class="px-6 py-4 font-headline font-bold text-on-surface text-sm hidden md:table-cell">What It Measures</th>
            </tr>
          </thead>
          <tbody class="text-on-surface-variant text-sm">
            {[
              { criteria: "Bonus Value", weight: "20%", measures: "Effective bonus value after wagering, fairness of terms" },
              { criteria: "Game Selection", weight: "20%", measures: "Variety, provider quality, count accuracy, crypto-native games" },
              { criteria: "Payment Speed", weight: "25%", measures: "Crypto deposit/withdrawal speed, limits, fees, supported coins", highlight: true },
              { criteria: "Trust & Security", weight: "25%", measures: "License status, payout reliability, responsible gambling tools", highlight: true },
              { criteria: "User Experience", weight: "10%", measures: "Interface quality, mobile experience, support responsiveness" },
            ].map((row) => (
              <tr class={`border-b border-outline-variant/10 ${row.highlight ? "bg-primary/5" : ""}`}>
                <td class="px-6 py-4 font-semibold text-on-surface">{row.criteria}</td>
                <td class="px-6 py-4 text-center font-headline font-bold text-primary">{row.weight}</td>
                <td class="px-6 py-4 hidden md:table-cell">{row.measures}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-on-surface-variant/60 mt-3">
        The final rating (0-10) is a weighted average rounded to one decimal place.
      </p>
    </section>

    <!-- Rating Scale -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-6">Rating Scale</h2>
      <div class="space-y-3">
        {ratingTiers.map((tier) => (
          <div class={`bg-surface-container-low rounded-xl p-5 border-l-4 border-${tier.color}-500 flex items-center gap-4`}>
            <span class={`material-symbols-outlined text-${tier.color}-500 shrink-0`}>{tier.icon}</span>
            <div class="flex-1 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4">
              <span class="font-headline font-bold text-on-surface w-28 shrink-0">{tier.range}</span>
              <span class={`font-label font-bold text-${tier.color}-500 w-28 shrink-0`}>{tier.label}</span>
              <span class="text-sm text-on-surface-variant">{tier.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Editorial Independence -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-6">Editorial Independence</h2>
      <div class="bg-surface-container-low rounded-xl p-8 space-y-4 text-on-surface-variant leading-relaxed">
        <p>
          CashSpins earns revenue through affiliate partnerships with the casinos we review. When you click a link and sign up, we may receive a commission. However, this commercial relationship has zero influence on our ratings, rankings, or editorial content.
        </p>
        <p>
          Our editorial team operates independently from our commercial partnerships. Reviewers do not know the commission structure of any casino, and no casino can pay to improve its position or score. If a highly profitable partner underperforms, it gets rated accordingly.
        </p>
        <p>
          Every review discloses: that the site contains affiliate links, that the reviewer deposited real funds, the date of the last verification, and the specific author who conducted the review.
        </p>
        <a href="/affiliate-disclosure/" class="inline-flex items-center gap-2 text-primary font-semibold hover:underline mt-2">
          <span class="material-symbols-outlined" style="font-size: 18px;">handshake</span>
          Read our full affiliate disclosure
        </a>
      </div>
    </section>

    <!-- Update Commitment -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-6">Update Commitment</h2>
      <div class="bg-surface-container-low rounded-xl p-8 space-y-4 text-on-surface-variant leading-relaxed">
        <p>
          Reviews are re-verified on a regular cycle. Bonus terms change, casinos update their game libraries, licenses get renewed or revoked. A review that was accurate six months ago may not reflect current reality.
        </p>
        <p>
          Every review displays the date it was last verified. When a casino changes its bonus terms, payment options, licensing status, or receives notable player complaints, we revisit and adjust the review. Most reviews are refreshed at least once per quarter.
        </p>
        <p>
          We aren't perfect. If a casino changes their terms overnight and we haven't caught it yet, we rely on our community to flag it — we update our reviews the moment a discrepancy is verified. Transparency means admitting when we're behind, not pretending we never are.
        </p>
      </div>
    </section>

    <!-- Our Reviewers -->
    <section class="mb-20">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-6">Our Reviewers</h2>
      <p class="text-on-surface-variant leading-relaxed mb-8">
        Every review is written by a named reviewer with industry experience. Each author follows our 8-step process, with particular focus areas based on their expertise.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {authors.map((author) => (
          <a href={`/team/${author.data.slug}/`} class="flex items-center gap-4 bg-surface-container-low rounded-xl p-5 hover:bg-surface-container transition-colors no-underline group">
            <img
              src={author.data.avatar}
              alt={author.data.name}
              width="48"
              height="48"
              class="w-12 h-12 rounded-full object-cover shrink-0"
              loading="lazy"
            />
            <div>
              <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors text-sm">{author.data.name}</h3>
              <p class="text-xs text-on-surface-variant mt-0.5 line-clamp-1">{author.data.bio?.slice(0, 80)}...</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Trust Page Cross-Links -->
    <section class="mb-16">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-8">Related Pages</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { href: "/about/", icon: "group", title: "About CashSpins", desc: "Meet the team behind the reviews" },
          { href: "/responsible-gambling/", icon: "shield", title: "Responsible Gambling", desc: "Help resources and self-exclusion tools" },
          { href: "/affiliate-disclosure/", icon: "handshake", title: "Affiliate Disclosure", desc: "How we earn revenue" },
          { href: "/contact/", icon: "mail", title: "Contact Us", desc: "Questions? Get in touch" },
        ].map((link) => (
          <a href={link.href} class="flex items-start gap-4 bg-surface-container-low rounded-xl p-6 hover:bg-surface-container transition-colors no-underline group">
            <span class="material-symbols-outlined text-primary text-2xl shrink-0 mt-0.5">{link.icon}</span>
            <div>
              <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">{link.title}</h3>
              <p class="text-sm text-on-surface-variant mt-1">{link.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <FAQSection faqs={faqs} />
    </section>
  </div>

  <script type="application/ld+json" set:html={generateFAQSchema(faqs)} />
</BaseLayout>
