---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { buildCanonical } from "../lib/seo";

const siteBase = "https://cashspins.online";

// ContactPage + contactPoint array. Each inbox is a separate ContactPoint so
// Google can surface the right email for "contact customer service" vs.
// "contact editorial" vs. "legal" queries.
const schemaJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact CashSpins",
  url: `${siteBase}/contact/`,
  description: "Get in touch with the CashSpins editorial team. Questions about reviews, affiliate partnerships, or responsible gambling resources.",
  isPartOf: { "@id": `${siteBase}/#website` },
  publisher: { "@id": `${siteBase}/#organization` },
  mainEntity: {
    "@type": "Organization",
    "@id": `${siteBase}/#organization`,
    name: "CashSpins",
    url: siteBase,
    contactPoint: [
      {
        "@type": "ContactPoint",
        contactType: "customer service",
        email: "info@cashspins.online",
        availableLanguage: ["English"],
        areaServed: "Worldwide",
      },
      {
        "@type": "ContactPoint",
        contactType: "editorial",
        email: "editorial@cashspins.online",
        availableLanguage: ["English"],
        areaServed: "Worldwide",
      },
      {
        "@type": "ContactPoint",
        contactType: "legal",
        email: "legal@cashspins.online",
        availableLanguage: ["English"],
        areaServed: "Worldwide",
      },
    ],
  },
});
---

<BaseLayout
  title="Contact Us | CashSpins"
  description="Get in touch with the CashSpins team. Questions about casino reviews, affiliate partnerships, or responsible gambling — we're here to help."
  canonical={buildCanonical("contact")}
  schemaJsonLd={schemaJsonLd}
>
  <div class="max-w-4xl mx-auto px-4 md:px-8 pt-8 pb-20">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Contact" },
    ]} />

    <header class="mt-8 mb-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="h-px w-12 bg-secondary/40"></span>
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-secondary">Get in Touch</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-headline font-extrabold tracking-tighter mb-6 leading-none text-on-surface">
        Contact Us
      </h1>
      <p class="max-w-2xl text-lg text-on-surface-variant leading-relaxed">
        Questions about a review? Want to report a concern about a casino? Think we got something wrong? We want to hear from you.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-8">Reach the Right Inbox</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="mailto:info@cashspins.online?subject=General%20Inquiry" class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container transition-colors no-underline group">
          <span class="material-symbols-outlined text-primary text-2xl mb-3 block">mail</span>
          <h3 class="font-headline font-bold text-on-surface mb-1 group-hover:text-primary transition-colors">General Inquiries</h3>
          <p class="text-sm text-on-surface-variant break-all">info@cashspins.online</p>
          <p class="text-xs text-on-surface-variant/60 mt-3">Suggest a casino, ask about a review, or anything else.</p>
        </a>
        <a href="mailto:editorial@cashspins.online?subject=Editorial%20Question%20or%20Correction" class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container transition-colors no-underline group">
          <span class="material-symbols-outlined text-primary text-2xl mb-3 block">edit_note</span>
          <h3 class="font-headline font-bold text-on-surface mb-1 group-hover:text-primary transition-colors">Editorial &amp; Corrections</h3>
          <p class="text-sm text-on-surface-variant break-all">editorial@cashspins.online</p>
          <p class="text-xs text-on-surface-variant/60 mt-3">Spot an error or want to flag a casino concern? Email us directly.</p>
        </a>
        <a href="mailto:legal@cashspins.online?subject=Legal%20or%20Privacy%20Request" class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container transition-colors no-underline group">
          <span class="material-symbols-outlined text-primary text-2xl mb-3 block">gavel</span>
          <h3 class="font-headline font-bold text-on-surface mb-1 group-hover:text-primary transition-colors">Legal &amp; Privacy</h3>
          <p class="text-sm text-on-surface-variant break-all">legal@cashspins.online</p>
          <p class="text-xs text-on-surface-variant/60 mt-3">DMCA, privacy requests, partnership/affiliate legal.</p>
        </a>
      </div>
      <p class="text-sm text-on-surface-variant/70 mt-6 max-w-2xl">
        We read every message and typically reply within 48 hours on business days. For the fastest response, include your topic in the email subject line and any relevant URLs in the body.
      </p>
    </section>

    <section>
      <h2 class="font-headline font-bold text-3xl text-on-surface mb-8">Looking for Something Else?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { href: "/how-we-review/", icon: "science", title: "How We Review", desc: "Our 8-step testing methodology" },
          { href: "/responsible-gambling/", icon: "shield", title: "Responsible Gambling", desc: "Help resources and self-exclusion tools" },
          { href: "/affiliate-disclosure/", icon: "handshake", title: "Affiliate Disclosure", desc: "How we earn revenue" },
          { href: "/about/", icon: "group", title: "About CashSpins", desc: "Meet the team behind the reviews" },
        ].map((link) => (
          <a href={link.href} class="flex items-start gap-4 bg-surface-container-low rounded-xl p-6 hover:bg-surface-container transition-colors no-underline group">
            <span class="material-symbols-outlined text-primary text-2xl shrink-0 mt-0.5">{link.icon}</span>
            <div>
              <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">{link.title}</h3>
              <p class="text-sm text-on-surface-variant mt-1">{link.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>

</BaseLayout>
