---
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  seoTitle?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  robots?: string;
  schemaJsonLd?: string;
  noIndex?: boolean;
  ogType?: "website" | "article";
}

const {
  title,
  seoTitle,
  description = "Casino reviews, bonuses, and guides from CasinoRank.",
  image,
  imageAlt,
  canonical,
  robots = "index, follow",
  schemaJsonLd,
  noIndex = false,
  ogType = "website",
} = Astro.props;

const pageTitle = seoTitle ?? title ?? "CasinoRank";
const ogImage = image ?? "/images/og-default.webp";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={noIndex ? "noindex, nofollow" : robots} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    {imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}

    <!-- Schema.org JSON-LD (pre-generated by pipeline) -->
    {schemaJsonLd && <script type="application/ld+json" set:html={schemaJsonLd} />}
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <nav class="site-footer__nav" aria-label="Footer navigation">
          <a href="/casinos/">Casino Reviews</a>
          <a href="/bonus/">Bonuses</a>
          <a href="/guides/">Guides</a>
          <a href="/news/">News</a>
          <a href="/about/">About</a>
          <a href="/responsible-gambling/">Responsible Gambling</a>
          <a href="/terms/">Terms</a>
          <a href="/privacy/">Privacy</a>
          <a href="/contact/">Contact</a>
        </nav>
        <p>© {new Date().getFullYear()} CasinoRank. All rights reserved.</p>
        <p class="site-footer__disclaimer">
          18+ only. Gambling can be addictive. Please gamble responsibly.
          <a href="https://www.begambleaware.org" rel="noopener noreferrer" target="_blank">GambleAware</a> &middot;
          <a href="https://www.gamblingtherapy.org" rel="noopener noreferrer" target="_blank">Gambling Therapy</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html { font-size: 16px; }
  body {
    margin: 0;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    background: #0b0b16;
    color: #d4d8ec;
    line-height: 1.65;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  main { flex: 1; }
  a { color: #f0c040; }
  a:hover { color: #fdd870; }
  img { max-width: 100%; height: auto; }
  h1, h2, h3, h4, h5, h6 { color: #eef0fa; line-height: 1.25; margin-top: 1.5em; margin-bottom: 0.5em; }
  h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); }
  h2 { font-size: clamp(1.25rem, 3vw, 1.75rem); }
  h3 { font-size: 1.2rem; }
  p { margin: 0 0 1rem; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 0.6rem 0.9rem; border: 1px solid rgba(255 255 255 / 0.1); text-align: left; }
  th { background: rgba(255 255 255 / 0.05); color: #eef0fa; font-weight: 600; }
  blockquote {
    margin: 1.25rem 0;
    padding: 0.75rem 1.1rem;
    border-left: 3px solid #f0c040;
    background: rgba(240 192 64 / 0.06);
    color: #b0b5cc;
    border-radius: 0 6px 6px 0;
  }
  code { background: rgba(255 255 255 / 0.07); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.88em; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; }

  /* ── Bonus Card (inline markdown component) ── */
  .bonus-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem 1.5rem;
    align-items: center;
    background: #14141f;
    border: 1px solid rgba(255 255 255 / 0.08);
    border-left: 3px solid #f0c040;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .bonus-card__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .bonus-card__logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: 8px;
  }
  .bonus-card__casino {
    font-size: 0.72rem;
    color: #7a80a0;
    text-align: center;
  }
  .bonus-card__offer {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .bonus-card__title {
    font-size: 1.05rem;
    color: #eef0fa;
  }
  .bonus-card__type {
    font-size: 0.78rem;
    color: #7a80a0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .bonus-card__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.25rem;
    font-size: 0.8rem;
    color: #b0b5cc;
    margin-top: 0.2rem;
  }
  .bonus-card__cta {
    display: inline-block;
    background: linear-gradient(135deg, #f0c040, #e07b20);
    color: #0b0b16;
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
  }
  .bonus-card__cta:hover { filter: brightness(1.1); color: #0b0b16; }
  @media (max-width: 600px) {
    .bonus-card { grid-template-columns: 1fr; }
    .bonus-card__cta { width: 100%; text-align: center; }
  }
</style>

<style>
  .site-footer {
    background: #0f0f1a;
    border-top: 1px solid rgba(255 255 255 / 0.07);
    padding: 1.5rem 0;
    margin-top: 4rem;
  }
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
    text-align: center;
  }
  .site-footer__nav {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 0.25rem 1rem; margin-bottom: 0.75rem;
  }
  .site-footer__nav a { font-size: 0.82rem; color: #6b7094; text-underline-offset: 2px; }
  .site-footer__nav a:hover { color: #9095b0; }
  .site-footer__inner p { margin: 0.25rem 0; font-size: 0.82rem; color: #6b7094; }
  .site-footer__disclaimer a { color: #6b7094; text-underline-offset: 2px; }
  .site-footer__disclaimer a:hover { color: #9095b0; }
</style>
